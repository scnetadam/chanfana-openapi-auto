:root,page{--gn-primary: #10b981;--gn-primary-dark: #059669;--gn-primary-light: #ecfdf5;--gn-accent: #2563eb;--gn-accent-light: #fefce8;--gn-success: #10b981;--gn-success-light: #ecfdf5;--gn-danger: #ef4444;--gn-warning: #f59e0b;--gn-text: #1f2937;--gn-text-secondary: #6b7280;--gn-text-tertiary: #9ca3af;--gn-bg: #f0f2f5;--gn-card: #ffffff;--gn-bg-muted: #f9fafb;--gn-border: #e5e7eb;--gn-border-light: #f3f4f6}page{background-color:var(--gn-bg);font-family:-apple-system,BlinkMacSystemFont,PingFang SC,Helvetica Neue,Microsoft YaHei,sans-serif;color:var(--gn-text);box-sizing:border-box;-webkit-font-smoothing:antialiased;font-size:28rpx}view,scroll-view,swiper{box-sizing:border-box}button{margin:0;padding:0;font-size:inherit;border:none;background:transparent}button:after{border:none}input,textarea{font-size:inherit;color:inherit;outline:none}::-webkit-scrollbar{width:0;height:0}.safe-bottom{padding-bottom:env(safe-area-inset-bottom)}.divider{height:2rpx;background:var(--gn-border-light);margin:0}@keyframes fadeIn{0%{opacity:0;transform:translateY(10rpx)}to{opacity:1;transform:translateY(0)}}.fade-in{animation:fadeIn .3s ease-out}
page::after{position:fixed;content:'';left:-1000px;top:-1000px;-webkit-animation:shadow-preload .1s;-webkit-animation-delay:3s;animation:shadow-preload .1s;animation-delay:3s}@-webkit-keyframes shadow-preload{0%{background-image:url(https://cdn2.dcloud.net.cn/4d6a41794d5441774e7a45324f4459304f4459354f53556c4d6a41794d5441774e7a45324f4459304f4459354f513d3d/img/shadow-grey.png)}100%{background-image:url(https://cdn2.dcloud.net.cn/4d6a41794d5441774e7a45324f4459304f4459354f53556c4d6a41794d5441774e7a45324f4459304f4459354f513d3d/img/shadow-grey.png)}}@keyframes shadow-preload{0%{background-image:url(https://cdn2.dcloud.net.cn/4d6a41794d5441774e7a45324f4459304f4459354f53556c4d6a41794d5441774e7a45324f4459304f4459354f513d3d/img/shadow-grey.png)}100%{background-image:url(https://cdn2.dcloud.net.cn/4d6a41794d5441774e7a45324f4459304f4459354f53556c4d6a41794d5441774e7a45324f4459304f4459354f513d3d/img/shadow-grey.png)}}page{--status-bar-height:25px;--top-window-height:0px;--window-top:0px;--window-bottom:0px;--window-left:0px;--window-right:0px;--window-magin:0px}