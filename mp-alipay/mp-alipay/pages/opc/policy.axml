<view class="policy-page data-v-e38becd6"><view class="header-card data-v-e38becd6"><text class="policy-title data-v-e38becd6">{{a}}</text><view class="policy-tags data-v-e38becd6"><text class="tag city data-v-e38becd6">{{b}}</text><text class="tag type data-v-e38becd6">{{c}}</text><text class="tag amount data-v-e38becd6">{{d}}</text><text class="{{('data-v-e38becd6') + ' ' + 'tag status' + ' ' + f}}">{{e}}</text></view></view><view class="info-card data-v-e38becd6"><view class="info-row data-v-e38becd6"><text class="info-label data-v-e38becd6">发布部门:</text><text class="info-value data-v-e38becd6">{{g}}</text></view><view class="info-row data-v-e38becd6"><text class="info-label data-v-e38becd6">申请截止:</text><text class="info-value highlight data-v-e38becd6">{{h}}</text></view><view class="info-row data-v-e38becd6"><text class="info-label data-v-e38becd6">联系电话:</text><text class="info-value link data-v-e38becd6" onTap="{{j}}">{{i}}</text></view></view><view class="section data-v-e38becd6"><text class="section-title data-v-e38becd6">📋 政策说明</text><text class="section-content data-v-e38becd6">{{k}}</text></view><view class="section data-v-e38becd6"><text class="section-title data-v-e38becd6">💰 扶持内容</text><view class="support-list data-v-e38becd6"><view a:for="{{l}}" a:for-item="item" a:key="c" class="support-item data-v-e38becd6"><text class="support-title data-v-e38becd6">{{item.a}}</text><text class="support-content data-v-e38becd6">{{item.b}}</text></view></view></view><view class="section data-v-e38becd6"><text class="section-title data-v-e38becd6">✅ 申请条件</text><view class="requirement-list data-v-e38becd6"><view a:for="{{m}}" a:for-item="req" a:key="c" class="requirement-item data-v-e38becd6"><text class="req-num data-v-e38becd6">{{req.a}}</text><text class="req-text data-v-e38becd6">{{req.b}}</text></view></view></view><view class="section data-v-e38becd6"><text class="section-title data-v-e38becd6">📄 申请材料</text><view class="material-list data-v-e38becd6"><view a:for="{{n}}" a:for-item="mat" a:key="b" class="material-item data-v-e38becd6"><text class="mat-icon data-v-e38becd6">📄</text><text class="mat-text data-v-e38becd6">{{mat.a}}</text></view></view></view><view class="section data-v-e38becd6"><text class="section-title data-v-e38becd6">🔄 办理流程</text><view class="process-list data-v-e38becd6"><view a:for="{{o}}" a:for-item="item" a:key="e" class="process-item data-v-e38becd6"><view class="process-left data-v-e38becd6"><text class="process-num data-v-e38becd6">{{item.a}}</text><view a:if="{{item.b}}" class="process-line data-v-e38becd6"/></view><view class="process-right data-v-e38becd6"><text class="process-title data-v-e38becd6">{{item.c}}</text><text class="process-desc data-v-e38becd6">{{item.d}}</text></view></view></view></view><view class="section data-v-e38becd6"><text class="section-title data-v-e38becd6">🏆 成功案例</text><view class="case-list data-v-e38becd6"><view a:for="{{p}}" a:for-item="caseItem" a:key="e" class="case-item data-v-e38becd6"><view class="case-header data-v-e38becd6"><text class="case-company data-v-e38becd6">{{caseItem.a}}</text><text class="case-year data-v-e38becd6">{{caseItem.b}}年</text></view><view class="case-info data-v-e38becd6"><text class="case-amount data-v-e38becd6">获得补贴: {{caseItem.c}}</text><text class="case-effect data-v-e38becd6">{{caseItem.d}}</text></view></view></view></view><view class="action-bar data-v-e38becd6"><button class="contact-btn data-v-e38becd6" onTap="{{q}}"><text class="btn-icon data-v-e38becd6">📞</text><text class="btn-text data-v-e38becd6">咨询</text></button><button class="apply-btn data-v-e38becd6" onTap="{{r}}"><text class="btn-icon data-v-e38becd6">🚀</text><text class="btn-text data-v-e38becd6">立即申请</text></button></view></view>