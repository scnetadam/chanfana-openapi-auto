.subsidy-page.data-v-79b1476b{min-height:100vh;background:#f5f5f5;padding-bottom:120rpx}.policy-card.data-v-79b1476b{background:linear-gradient(135deg,#667eea,#764ba2);padding:40rpx 30rpx;color:#fff}.policy-title.data-v-79b1476b{display:block;font-size:36rpx;font-weight:700;margin-bottom:20rpx}.policy-tags.data-v-79b1476b{display:flex;gap:12rpx}.tag.data-v-79b1476b{padding:8rpx 20rpx;background:rgba(255,255,255,.2);border-radius:20rpx;font-size:24rpx}.tag.highlight.data-v-79b1476b{background:#fff;color:#667eea}.form-section.data-v-79b1476b{background:#fff;margin:24rpx 0;padding:30rpx}.section-title.data-v-79b1476b{display:block;font-size:32rpx;font-weight:700;color:#333;margin-bottom:24rpx}.section-tip.data-v-79b1476b{display:block;font-size:24rpx;color:#999;margin-bottom:20rpx}.form-item.data-v-79b1476b{margin-bottom:30rpx}.label.data-v-79b1476b{display:block;font-size:28rpx;color:#333;margin-bottom:12rpx}.label.required.data-v-79b1476b:before{content:"*";color:#f5576c;margin-right:4rpx}.input.data-v-79b1476b,.textarea.data-v-79b1476b,.picker.data-v-79b1476b{width:100%;padding:24rpx;background:#f8f9fa;border-radius:12rpx;font-size:28rpx;color:#333}.textarea.data-v-79b1476b{min-height:200rpx}.picker.data-v-79b1476b{display:flex;justify-content:space-between;align-items:center}.picker text.data-v-79b1476b:not(.arrow){flex:1;color:#999}.picker text.has-value.data-v-79b1476b{color:#333}.arrow.data-v-79b1476b{font-size:32rpx;color:#999}.attachment-list.data-v-79b1476b{display:flex;flex-direction:column;gap:16rpx}.attachment-item.data-v-79b1476b{display:flex;align-items:center;padding:24rpx;background:#f8f9fa;border-radius:12rpx}.file-icon.data-v-79b1476b{font-size:32rpx;margin-right:16rpx}.file-name.data-v-79b1476b{flex:1;font-size:26rpx;color:#333}.remove-btn.data-v-79b1476b{font-size:32rpx;color:#999;padding:0 10rpx}.add-attachment.data-v-79b1476b{display:flex;align-items:center;justify-content:center;padding:24rpx;background:#f8f9fa;border-radius:12rpx;border:2rpx dashed #ddd}.add-icon.data-v-79b1476b{font-size:40rpx;color:#999;margin-right:12rpx}.add-text.data-v-79b1476b{font-size:26rpx;color:#999}.submit-bar.data-v-79b1476b{position:fixed;bottom:0;left:0;right:0;padding:20rpx 30rpx;background:#fff;box-shadow:0 -4rpx 12rpx rgba(0,0,0,.05)}.submit-btn.data-v-79b1476b{width:100%;padding:28rpx;background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;border:none;border-radius:16rpx;font-size:32rpx;font-weight:500}