<view class="apply-page data-v-e8f4ee9b"><view class="progress-bar data-v-e8f4ee9b"><view class="{{('data-v-e8f4ee9b') + ' ' + 'progress-step' + ' ' + a}}"><text class="step-num data-v-e8f4ee9b">1</text><text class="step-label data-v-e8f4ee9b">企业信息</text></view><view class="progress-line data-v-e8f4ee9b" style="{{'background:' + b}}"/><view class="{{('data-v-e8f4ee9b') + ' ' + 'progress-step' + ' ' + c}}"><text class="step-num data-v-e8f4ee9b">2</text><text class="step-label data-v-e8f4ee9b">项目信息</text></view><view class="progress-line data-v-e8f4ee9b" style="{{'background:' + d}}"/><view class="{{('data-v-e8f4ee9b') + ' ' + 'progress-step' + ' ' + e}}"><text class="step-num data-v-e8f4ee9b">3</text><text class="step-label data-v-e8f4ee9b">联系方式</text></view><view class="progress-line data-v-e8f4ee9b" style="{{'background:' + f}}"/><view class="{{('data-v-e8f4ee9b') + ' ' + 'progress-step' + ' ' + g}}"><text class="step-num data-v-e8f4ee9b">4</text><text class="step-label data-v-e8f4ee9b">提交申请</text></view></view><view a:if="{{h}}" class="step-content data-v-e8f4ee9b"><view class="form-section data-v-e8f4ee9b"><text class="section-title data-v-e8f4ee9b">企业基本信息</text><view class="form-item data-v-e8f4ee9b"><text class="label required data-v-e8f4ee9b">公司名称</text><input class="input data-v-e8f4ee9b" placeholder="请输入公司全称" value="{{i}}" onInput="{{j}}"/></view><view class="form-item data-v-e8f4ee9b"><text class="label required data-v-e8f4ee9b">统一社会信用代码</text><input class="input data-v-e8f4ee9b" placeholder="请输入18位信用代码" value="{{k}}" onInput="{{l}}"/></view><view class="form-item data-v-e8f4ee9b"><text class="label required data-v-e8f4ee9b">入驻城市</text><picker class="data-v-e8f4ee9b" mode="selector" range="{{o}}" onChange="{{p}}"><view class="picker data-v-e8f4ee9b"><text class="{{('data-v-e8f4ee9b') + ' ' + n}}">{{m}}</text><text class="arrow data-v-e8f4ee9b">›</text></view></picker></view></view></view><view a:if="{{q}}" class="step-content data-v-e8f4ee9b"><view class="form-section data-v-e8f4ee9b"><text class="section-title data-v-e8f4ee9b">项目信息</text><view class="form-item data-v-e8f4ee9b"><text class="label required data-v-e8f4ee9b">项目类型</text><picker class="data-v-e8f4ee9b" mode="selector" range="{{t}}" onChange="{{v}}"><view class="picker data-v-e8f4ee9b"><text class="{{('data-v-e8f4ee9b') + ' ' + s}}">{{r}}</text><text class="arrow data-v-e8f4ee9b">›</text></view></picker></view><view class="form-item data-v-e8f4ee9b"><text class="label required data-v-e8f4ee9b">项目名称</text><input class="input data-v-e8f4ee9b" placeholder="请输入项目名称" value="{{w}}" onInput="{{x}}"/></view><view class="form-item data-v-e8f4ee9b"><text class="label required data-v-e8f4ee9b">项目简介</text><textarea class="textarea data-v-e8f4ee9b" placeholder="请详细描述您的AI项目（技术方向、应用场景、商业模式等）" maxlength="500" value="{{y}}" onInput="{{z}}"/></view><view class="form-item data-v-e8f4ee9b"><text class="label data-v-e8f4ee9b">团队规模</text><input class="input data-v-e8f4ee9b" placeholder="例如：35人" value="{{A}}" onInput="{{B}}"/></view><view class="form-item data-v-e8f4ee9b"><text class="label data-v-e8f4ee9b">已获融资</text><input class="input data-v-e8f4ee9b" placeholder="例如：A轮2000万" value="{{C}}" onInput="{{D}}"/></view></view></view><view a:if="{{E}}" class="step-content data-v-e8f4ee9b"><view class="form-section data-v-e8f4ee9b"><text class="section-title data-v-e8f4ee9b">创始人信息</text><view class="form-item data-v-e8f4ee9b"><text class="label required data-v-e8f4ee9b">创始人姓名</text><input class="input data-v-e8f4ee9b" placeholder="请输入创始人姓名" value="{{F}}" onInput="{{G}}"/></view><view class="form-item data-v-e8f4ee9b"><text class="label required data-v-e8f4ee9b">联系电话</text><input class="input data-v-e8f4ee9b" placeholder="请输入手机号" type="number" value="{{H}}" onInput="{{I}}"/></view><view class="form-item data-v-e8f4ee9b"><text class="label data-v-e8f4ee9b">联系邮箱</text><input class="input data-v-e8f4ee9b" placeholder="请输入邮箱" value="{{J}}" onInput="{{K}}"/></view><view class="form-item data-v-e8f4ee9b"><text class="label data-v-e8f4ee9b">创始人背景</text><textarea class="textarea data-v-e8f4ee9b" placeholder="学历、工作经历、创业经历等" maxlength="300" value="{{L}}" onInput="{{M}}"/></view></view></view><view a:if="{{N}}" class="step-content data-v-e8f4ee9b"><view class="form-section data-v-e8f4ee9b"><text class="section-title data-v-e8f4ee9b">期望支持</text><text class="section-tip data-v-e8f4ee9b">请选择您希望获得的支持类型（可多选）</text><view class="expectation-grid data-v-e8f4ee9b"><view a:for="{{O}}" a:for-item="item" a:key="c" class="{{('data-v-e8f4ee9b') + ' ' + 'expectation-item' + ' ' + item.d}}" onTap="{{item.e}}"><text class="check-icon data-v-e8f4ee9b">{{item.a}}</text><text class="item-text data-v-e8f4ee9b">{{item.b}}</text></view></view></view><view class="form-section data-v-e8f4ee9b"><text class="section-title data-v-e8f4ee9b">商业计划</text><textarea class="textarea data-v-e8f4ee9b" placeholder="请简要描述您的商业计划和发展规划（选填）" maxlength="500" value="{{P}}" onInput="{{Q}}"/></view><view class="terms-section data-v-e8f4ee9b"><view class="terms-checkbox data-v-e8f4ee9b" onTap="{{S}}"><text class="checkbox data-v-e8f4ee9b">{{R}}</text><text class="terms-text data-v-e8f4ee9b">我已阅读并同意《OPC创业广场入驻协议》</text></view></view></view><view class="action-bar data-v-e8f4ee9b"><button a:if="{{T}}" class="action-btn secondary data-v-e8f4ee9b" onTap="{{U}}">上一步</button><button a:if="{{V}}" class="action-btn primary data-v-e8f4ee9b" onTap="{{W}}">下一步</button><button a:if="{{X}}" class="action-btn primary data-v-e8f4ee9b" loading="{{Y}}" disabled="{{Z}}" onTap="{{aa}}">提交申请</button></view></view>