<view class="subsidy-page data-v-79b1476b"><view class="policy-card data-v-79b1476b"><text class="policy-title data-v-79b1476b">{{a}}</text><view class="policy-tags data-v-79b1476b"><text class="tag data-v-79b1476b">{{b}}</text><text class="tag highlight data-v-79b1476b">{{c}}</text><text class="tag data-v-79b1476b">{{d}}</text></view></view><view class="form-section data-v-79b1476b"><text class="section-title data-v-79b1476b">企业信息</text><view class="form-item data-v-79b1476b"><text class="label required data-v-79b1476b">公司名称</text><input class="input data-v-79b1476b" placeholder="请输入公司全称" value="{{e}}" onInput="{{f}}"/></view><view class="form-item data-v-79b1476b"><text class="label required data-v-79b1476b">统一社会信用代码</text><input class="input data-v-79b1476b" placeholder="请输入18位信用代码" value="{{g}}" onInput="{{h}}"/></view><view class="form-item data-v-79b1476b"><text class="label required data-v-79b1476b">法人代表</text><input class="input data-v-79b1476b" placeholder="请输入法人姓名" value="{{i}}" onInput="{{j}}"/></view><view class="form-item data-v-79b1476b"><text class="label required data-v-79b1476b">联系电话</text><input class="input data-v-79b1476b" placeholder="请输入手机号" type="number" value="{{k}}" onInput="{{l}}"/></view><view class="form-item data-v-79b1476b"><text class="label data-v-79b1476b">联系邮箱</text><input class="input data-v-79b1476b" placeholder="请输入邮箱地址" value="{{m}}" onInput="{{n}}"/></view></view><view class="form-section data-v-79b1476b"><text class="section-title data-v-79b1476b">项目信息</text><view class="form-item data-v-79b1476b"><text class="label required data-v-79b1476b">项目类型</text><picker class="data-v-79b1476b" mode="selector" range="{{q}}" onChange="{{r}}"><view class="picker data-v-79b1476b"><text class="{{('data-v-79b1476b') + ' ' + p}}">{{o}}</text><text class="arrow data-v-79b1476b">›</text></view></picker></view><view class="form-item data-v-79b1476b"><text class="label required data-v-79b1476b">项目简介</text><textarea class="textarea data-v-79b1476b" placeholder="请简要描述您的AI项目（200字以内）" maxlength="200" value="{{s}}" onInput="{{t}}"/></view><view class="form-item data-v-79b1476b"><text class="label required data-v-79b1476b">团队规模</text><picker class="data-v-79b1476b" mode="selector" range="{{x}}" onChange="{{y}}"><view class="picker data-v-79b1476b"><text class="{{('data-v-79b1476b') + ' ' + w}}">{{v}}</text><text class="arrow data-v-79b1476b">›</text></view></picker></view><view class="form-item data-v-79b1476b"><text class="label data-v-79b1476b">已获融资</text><input class="input data-v-79b1476b" placeholder="例如：天使轮500万" value="{{z}}" onInput="{{A}}"/></view></view><view class="form-section data-v-79b1476b"><text class="section-title data-v-79b1476b">附件材料</text><text class="section-tip data-v-79b1476b">请上传营业执照、项目计划书等相关材料（PDF/图片）</text><view class="attachment-list data-v-79b1476b"><view a:for="{{B}}" a:for-item="file" a:key="c" class="attachment-item data-v-79b1476b"><text class="file-icon data-v-79b1476b">📄</text><text class="file-name data-v-79b1476b">{{file.a}}</text><text class="remove-btn data-v-79b1476b" onTap="{{file.b}}">✕</text></view><view class="add-attachment data-v-79b1476b" onTap="{{C}}"><text class="add-icon data-v-79b1476b">+</text><text class="add-text data-v-79b1476b">添加附件</text></view></view></view><view class="submit-bar data-v-79b1476b"><button class="submit-btn data-v-79b1476b" loading="{{D}}" disabled="{{E}}" onTap="{{F}}"><text class="data-v-79b1476b">提交申请</text></button></view></view>