.apply-page.data-v-e8f4ee9b{min-height:100vh;background:#f5f5f5;padding-bottom:120rpx}.progress-bar.data-v-e8f4ee9b{display:flex;align-items:center;justify-content:center;padding:30rpx;background:#fff}.progress-step.data-v-e8f4ee9b{display:flex;flex-direction:column;align-items:center}.step-num.data-v-e8f4ee9b{width:48rpx;height:48rpx;border-radius:50%;background:#ddd;color:#fff;display:flex;align-items:center;justify-content:center;font-size:24rpx;font-weight:700;margin-bottom:8rpx}.progress-step.active .step-num.data-v-e8f4ee9b{background:linear-gradient(135deg,#667eea,#764ba2)}.step-label.data-v-e8f4ee9b{font-size:22rpx;color:#999}.progress-step.active .step-label.data-v-e8f4ee9b{color:#667eea;font-weight:500}.progress-line.data-v-e8f4ee9b{width:60rpx;height:4rpx;margin:0 10rpx 30rpx}.step-content.data-v-e8f4ee9b{padding:30rpx}.form-section.data-v-e8f4ee9b{background:#fff;border-radius:16rpx;padding:30rpx;margin-bottom:24rpx}.section-title.data-v-e8f4ee9b{display:block;font-size:32rpx;font-weight:700;color:#333;margin-bottom:24rpx}.section-tip.data-v-e8f4ee9b{display:block;font-size:24rpx;color:#999;margin-bottom:20rpx}.form-item.data-v-e8f4ee9b{margin-bottom:30rpx}.label.data-v-e8f4ee9b{display:block;font-size:28rpx;color:#333;margin-bottom:12rpx}.label.required.data-v-e8f4ee9b:before{content:"*";color:#f5576c;margin-right:4rpx}.input.data-v-e8f4ee9b,.textarea.data-v-e8f4ee9b,.picker.data-v-e8f4ee9b{width:100%;padding:24rpx;background:#f8f9fa;border-radius:12rpx;font-size:28rpx;color:#333}.textarea.data-v-e8f4ee9b{min-height:200rpx}.picker.data-v-e8f4ee9b{display:flex;justify-content:space-between;align-items:center}.picker text.data-v-e8f4ee9b:not(.arrow){flex:1;color:#999}.picker text.has-value.data-v-e8f4ee9b{color:#333}.arrow.data-v-e8f4ee9b{font-size:32rpx;color:#999}.expectation-grid.data-v-e8f4ee9b{display:grid;grid-template-columns:repeat(2,1fr);gap:20rpx}.expectation-item.data-v-e8f4ee9b{display:flex;align-items:center;padding:24rpx;background:#f8f9fa;border-radius:12rpx;border:2rpx solid transparent}.expectation-item.active.data-v-e8f4ee9b{background:#e3f2fd;border-color:#667eea}.check-icon.data-v-e8f4ee9b{width:36rpx;height:36rpx;border-radius:50%;background:#ddd;color:#fff;display:flex;align-items:center;justify-content:center;font-size:24rpx;margin-right:16rpx}.expectation-item.active .check-icon.data-v-e8f4ee9b{background:linear-gradient(135deg,#667eea,#764ba2)}.item-text.data-v-e8f4ee9b{font-size:26rpx;color:#333}.terms-section.data-v-e8f4ee9b{background:#fff;border-radius:16rpx;padding:30rpx}.terms-checkbox.data-v-e8f4ee9b{display:flex;align-items:center}.checkbox.data-v-e8f4ee9b{width:36rpx;height:36rpx;border-radius:6rpx;border:2rpx solid #ddd;display:flex;align-items:center;justify-content:center;font-size:24rpx;color:#667eea;margin-right:16rpx}.terms-text.data-v-e8f4ee9b{font-size:26rpx;color:#333}.action-bar.data-v-e8f4ee9b{position:fixed;bottom:0;left:0;right:0;display:flex;gap:20rpx;padding:20rpx 30rpx;background:#fff;box-shadow:0 -4rpx 12rpx rgba(0,0,0,.05)}.action-btn.data-v-e8f4ee9b{flex:1;padding:28rpx;border-radius:16rpx;font-size:32rpx;font-weight:500;border:none}.action-btn.primary.data-v-e8f4ee9b{background:linear-gradient(135deg,#667eea,#764ba2);color:#fff}.action-btn.secondary.data-v-e8f4ee9b{background:#f5f5f5;color:#666}