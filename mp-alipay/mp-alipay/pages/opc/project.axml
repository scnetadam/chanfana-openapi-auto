<view class="project-page data-v-b89f56fe"><view class="search-bar data-v-b89f56fe"><input class="search-input data-v-b89f56fe" placeholder="搜索项目、公司、标签..." value="{{a}}" onInput="{{b}}"/></view><view class="filter-bar data-v-b89f56fe"><view class="{{('data-v-b89f56fe') + ' ' + 'filter-item' + ' ' + c}}" onTap="{{d}}"><text class="data-v-b89f56fe">全部</text></view><view class="{{('data-v-b89f56fe') + ' ' + 'filter-item' + ' ' + e}}" onTap="{{f}}"><text class="data-v-b89f56fe">🔥 热门</text></view><view class="{{('data-v-b89f56fe') + ' ' + 'filter-item' + ' ' + g}}" onTap="{{h}}"><text class="data-v-b89f56fe">✨ 最新</text></view><view class="{{('data-v-b89f56fe') + ' ' + 'filter-item' + ' ' + i}}" onTap="{{j}}"><text class="data-v-b89f56fe">💰 融资中</text></view></view><view class="project-list data-v-b89f56fe"><view a:for="{{k}}" a:for-item="project" a:key="q" class="project-card data-v-b89f56fe" onTap="{{project.r}}"><view class="project-header data-v-b89f56fe"><view class="project-title-row data-v-b89f56fe"><text class="project-name data-v-b89f56fe">{{project.a}}</text><text class="project-stage data-v-b89f56fe">{{project.b}}</text></view><text class="project-company data-v-b89f56fe">{{project.c}}</text><view class="project-tags data-v-b89f56fe"><text class="tag city data-v-b89f56fe">{{project.d}}</text><text a:for="{{project.e}}" a:for-item="tag" a:key="b" class="tag data-v-b89f56fe">{{tag.a}}</text></view></view><text class="project-desc data-v-b89f56fe">{{project.f}}</text><view class="project-metrics data-v-b89f56fe"><view class="metric-item data-v-b89f56fe"><text class="metric-label data-v-b89f56fe">用户规模</text><text class="metric-value data-v-b89f56fe">{{project.g}}</text></view><view class="metric-item data-v-b89f56fe"><text class="metric-label data-v-b89f56fe">年营收</text><text class="metric-value data-v-b89f56fe">{{project.h}}</text></view><view class="metric-item data-v-b89f56fe"><text class="metric-label data-v-b89f56fe">增长率</text><text class="metric-value highlight data-v-b89f56fe">{{project.i}}</text></view></view><view class="project-info data-v-b89f56fe"><view class="info-item data-v-b89f56fe"><text class="info-label data-v-b89f56fe">融资:</text><text class="info-value data-v-b89f56fe">{{project.j}}</text></view><view class="info-item data-v-b89f56fe"><text class="info-label data-v-b89f56fe">估值:</text><text class="info-value data-v-b89f56fe">{{project.k}}</text></view><view class="info-item data-v-b89f56fe"><text class="info-label data-v-b89f56fe">团队:</text><text class="info-value data-v-b89f56fe">{{project.l}}</text></view></view><view class="founder-info data-v-b89f56fe"><text class="founder-label data-v-b89f56fe">创始人:</text><text class="founder-name data-v-b89f56fe">{{project.m}}</text><text class="founder-bg data-v-b89f56fe">{{project.n}}</text></view><view class="project-footer data-v-b89f56fe"><text class="founded-time data-v-b89f56fe">成立于 {{project.o}}</text><button class="contact-btn data-v-b89f56fe" catchTap="{{project.p}}">联系合作</button></view></view></view></view>