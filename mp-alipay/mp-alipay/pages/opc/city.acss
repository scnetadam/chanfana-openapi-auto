.city-page.data-v-9e07e1c5{min-height:100vh;background:#f5f5f5;padding-bottom:40rpx}.header-card.data-v-9e07e1c5{background:linear-gradient(135deg,#667eea,#764ba2);padding:40rpx 30rpx;color:#fff}.city-header.data-v-9e07e1c5{margin-bottom:20rpx}.city-name.data-v-9e07e1c5{display:block;font-size:48rpx;font-weight:700;margin-bottom:10rpx}.city-province.data-v-9e07e1c5{display:block;font-size:28rpx;opacity:.8}.city-desc.data-v-9e07e1c5{display:block;font-size:26rpx;opacity:.9;margin-bottom:30rpx;line-height:1.6}.city-stats.data-v-9e07e1c5{display:grid;grid-template-columns:repeat(4,1fr);gap:20rpx;background:rgba(255,255,255,.15);border-radius:16rpx;padding:24rpx;margin-bottom:24rpx}.stat-item.data-v-9e07e1c5{text-align:center}.stat-value.data-v-9e07e1c5{display:block;font-size:32rpx;font-weight:700;margin-bottom:8rpx}.stat-label.data-v-9e07e1c5{display:block;font-size:22rpx;opacity:.8}.feature-tags.data-v-9e07e1c5{display:flex;flex-wrap:wrap;gap:16rpx}.feature-tag.data-v-9e07e1c5{padding:10rpx 20rpx;background:rgba(255,255,255,.2);border-radius:20rpx;font-size:24rpx}.tabs.data-v-9e07e1c5{display:flex;background:#fff;border-bottom:1rpx solid #eee}.tab.data-v-9e07e1c5{flex:1;text-align:center;padding:30rpx 0;font-size:30rpx;color:#666;position:relative}.tab.active.data-v-9e07e1c5{color:#667eea;font-weight:700}.tab.active.data-v-9e07e1c5:after{content:"";position:absolute;bottom:0;left:50%;transform:translate(-50%);width:60rpx;height:4rpx;background:#667eea;border-radius:2rpx}.policy-section.data-v-9e07e1c5,.project-section.data-v-9e07e1c5{padding:30rpx}.policy-card.data-v-9e07e1c5{background:#fff;border-radius:16rpx;padding:30rpx;margin-bottom:24rpx;box-shadow:0 4rpx 12rpx rgba(0,0,0,.05)}.policy-header.data-v-9e07e1c5{margin-bottom:16rpx}.policy-title-row.data-v-9e07e1c5{display:flex;justify-content:space-between;align-items:center;margin-bottom:12rpx}.policy-title.data-v-9e07e1c5{font-size:32rpx;font-weight:700;color:#333;flex:1}.status.data-v-9e07e1c5{padding:6rpx 16rp