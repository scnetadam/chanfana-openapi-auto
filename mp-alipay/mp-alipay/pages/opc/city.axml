<view class="city-page data-v-9e07e1c5"><view class="header-card data-v-9e07e1c5"><view class="city-header data-v-9e07e1c5"><text class="city-name data-v-9e07e1c5">{{a}}</text><text class="city-province data-v-9e07e1c5">{{b}}</text></view><text class="city-desc data-v-9e07e1c5">{{c}}</text><view class="city-stats data-v-9e07e1c5"><view class="stat-item data-v-9e07e1c5"><text class="stat-value data-v-9e07e1c5">{{d}}</text><text class="stat-label data-v-9e07e1c5">创业项目</text></view><view class="stat-item data-v-9e07e1c5"><text class="stat-value data-v-9e07e1c5">{{e}}</text><text class="stat-label data-v-9e07e1c5">投资补贴</text></view><view class="stat-item data-v-9e07e1c5"><text class="stat-value data-v-9e07e1c5">{{f}}</text><text class="stat-label data-v-9e07e1c5">TOKEN池</text></view><view class="stat-item data-v-9e07e1c5"><text class="stat-value data-v-9e07e1c5">{{g}}</text><text class="stat-label data-v-9e07e1c5">扶持政策</text></view></view><view class="feature-tags data-v-9e07e1c5"><text a:for="{{h}}" a:for-item="feature" a:key="b" class="feature-tag data-v-9e07e1c5">{{feature.a}}</text></view></view><view class="tabs data-v-9e07e1c5"><view class="{{('data-v-9e07e1c5') + ' ' + 'tab' + ' ' + i}}" onTap="{{j}}"><text class="data-v-9e07e1c5">扶持政策</text></view><view class="{{('data-v-9e07e1c5') + ' ' + 'tab' + ' ' + k}}" onTap="{{l}}"><text class="data-v-9e07e1c5">创业项目</text></view></view><view a:if="{{m}}" class="policy-section data-v-9e07e1c5"><view a:for="{{n}}" a:for-item="policy" a:key="k" class="policy-card data-v-9e07e1c5"><view class="policy-header data-v-9e07e1c5" onTap="{{policy.f}}"><view class="policy-title-row data-v-9e07e1c5"><text class="policy-title data-v-9e07e1c5">{{policy.a}}</text><text class="{{('data-v-9e07e1c5') + ' ' + 'status' + ' ' + policy.c}}">{{policy.b}}</text></view><view class="policy-tags data-v-9e07e1c5"><text class="tag type data-v-9e07e1c5">{{policy.d}}</text><text class="tag amount data-v-9e07e1c5">{{policy.e}}</text></view></view><text class="policy-desc data-v-9e07e1c5">{{policy.g}}</text><view class="policy-requirements data-v-9e07e1c5"><text class="req-label data-v-9e07e1c5">申请条件:</text><text a:for="{{policy.h}}" a:for-item="req" a:key="b" class="req-item data-v-9e07e1c5">{{req.a}}</text></view><view class="policy-footer data-v-9e07e1c5"><text class="deadline data-v-9e07e1c5">截止: {{policy.i}}</text><button class="apply-btn data-v-9e07e1c5" onTap="{{policy.j}}">立即申请</button></view></view></view><view a:if="{{o}}" class="project-section data-v-9e07e1c5"><view a:for="{{p}}" a:for-item="project" a:key="f" class="project-card data-v-9e07e1c5" onTap="{{project.g}}"><view class="project-header data-v-9e07e1c5"><text class="project-name data-v-9e07e1c5">{{project.a}}</text><text class="project-stage data-v-9e07e1c5">{{project.b}}</text></view><text class="project-company data-v-9e07e1c5">{{project.c}}</text><view class="project-info data-v-9e07e1c5"><text class="funding data-v-9e07e1c5">融资: {{project.d}}</text><view class="project-tags data-v-9e07e1c5"><text a:for="{{project.e}}" a:for-item="tag" a:key="b" class="tag data-v-9e07e1c5">{{tag.a}}</text></view></view></view></view></view>