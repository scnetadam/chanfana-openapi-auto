<view class="page data-v-c0mp1ance"><view class="header data-v-c0mp1ance"><text class="header-title data-v-c0mp1ance">合规看板</text><text class="header-sub data-v-c0mp1ance">龟钮自驭合规监控</text></view><view a:if="{{a}}" class="loading data-v-c0mp1ance"><text class="data-v-c0mp1ance">加载中...</text></view><view a:elif="{{b}}" class="data-v-c0mp1ance"><view class="stats-grid data-v-c0mp1ance"><view class="stat-card data-v-c0mp1ance"><text class="stat-val data-v-c0mp1ance">{{b}}</text><text class="stat-lbl data-v-c0mp1ance">核查总数</text></view><view class="stat-card data-v-c0mp1ance"><text class="stat-val {{d}} data-v-c0mp1ance">{{c}}%</text><text class="stat-lbl data-v-c0mp1ance">匹配率</text></view><view class="stat-card green data-v-c0mp1ance"><text class="stat-val data-v-c0mp1ance">{{e}}</text><text class="stat-lbl data-v-c0mp1ance">已匹配</text></view><view class="stat-card red data-v-c0mp1ance"><text class="stat-val data-v-c0mp1ance">{{f}}</text><text class="stat-lbl data-v-c0mp1ance">不匹配</text></view></view><view class="section data-v-c0mp1ance"><text class="section-title data-v-c0mp1ance">KOL轨道分布</text><view a:for="{{g}}" a:for-item="item" a:key="f" class="dist-bar data-v-c0mp1ance"><view class="dist-label data-v-c0mp1ance"><text class="dist-track {{item.d}} data-v-c0mp1ance">{{item.a}}</text><text class="dist-count data-v-c0mp1ance">{{item.b}}人 ({{item.c}}%)</text></view><view class="dist-track-bar data-v-c0mp1ance"><view class="dist-fill {{item.d}} data-v-c0mp1ance" style="width:{{item.e}}%"></view></view></view></view><view a:if="{{h}}" class="section data-v-c0mp1ance"><text class="section-title data-v-c0mp1ance">近期不匹配</text><view a:for="{{i}}" a:for-item="item" a:key="f" class="mismatch-card data-v-c0mp1ance"><view class="mismatch-top data-v-c0mp1ance"><text class="mismatch-hash data-v-c0mp1ance">{{item.a}}</text><text class="mismatch-status {{item.c}} data-v-c0mp1ance">{{item.b}}</text></view><view class="mismatch-bottom data-v-c0mp1ance"><text class="mismatch-amount data-v-c0mp1ance">¥{{item.d}}</text><text class="mismatch-date data-v-c0mp1ance">{{item.e}}</text></view></view></view></view><view a:else class="empty data-v-c0mp1ance"><text class="data-v-c0mp1ance">暂无合规数据</text></view></view>