<view class="dashboard-page data-v-0932422e"><view class="user-header data-v-0932422e"><view class="uh-left data-v-0932422e"><view class="uh-avatar data-v-0932422e"><image class="avatar-img data-v-0932422e" src="{{a}}" mode="aspectFill"/></view><view class="uh-info data-v-0932422e"><text class="uh-name data-v-0932422e">{{b}}</text><text class="uh-role data-v-0932422e">🚗 推广员 · X402</text></view></view><view class="uh-right data-v-0932422e"><button class="publish-mini-btn data-v-0932422e" onTap="{{c}}"><text class="data-v-0932422e">➕</text></button></view></view><view class="stats-row data-v-0932422e"><view class="stats-card data-v-0932422e"><text class="st-value data-v-0932422e">{{d}}</text><text class="st-label data-v-0932422e">发布内容</text></view><view class="stats-card data-v-0932422e"><text class="st-value data-v-0932422e">{{e}}</text><text class="st-label data-v-0932422e">总阅读</text></view><view class="stats-card data-v-0932422e"><text class="st-value accent data-v-0932422e">{{f}}</text><text class="st-label data-v-0932422e">总预约</text></view><view class="stats-card data-v-0932422e"><text class="st-value gold data-v-0932422e">¥{{g}}</text><text class="st-label data-v-0932422e">总收益</text></view></view><view a:if="{{h}}" class="ai-insight-section data-v-0932422e"><view class="ai-insight-loading data-v-0932422e"><text class="data-v-0932422e">✨ AI 洞察分析中...</text></view></view><view a:elif="{{i}}" class="ai-insight-section data-v-0932422e"><view class="ai-insight-header data-v-0932422e"><text class="ai-insight-title data-v-0932422e">✨ AI 数据洞察</text><text class="ai-insight-badge data-v-0932422e">NEW</text></view><text a:if="{{j}}" class="ai-insight-summary data-v-0932422e">{{k}}</text><view a:for="{{l}}" a:for-item="insight" a:key="d" class="ai-insight-card data-v-0932422e"><view class="aic-icon-wrap data-v-0932422e"><text class="aic-icon data-v-0932422e">{{insight.a}}</text></view><view class="aic-body data-v-0932422e"><text class="aic-title data-v-0932422e">{{insight.b}}</text><text class="aic-detail data-v-0932422e">{{insight.c}}</text></view></view></view><view a:if="{{m}}" class="loading-state data-v-0932422e"><text class="loading-text data-v-0932422e">加载中...</text></view><view a:elif="{{n}}" class="empty-state data-v-0932422e"><text class="empty-icon data-v-0932422e">📝</text><text class="empty-text data-v-0932422e">还没有发布过内容</text><text class="empty-hint data-v-0932422e">去活动页选择一个推广活动开始发布吧</text><button class="empty-btn data-v-0932422e" onTap="{{o}}">去发布</button></view><view a:else class="content-list data-v-0932422e"><view class="list-header data-v-0932422e"><text class="list-title data-v-0932422e">我的内容</text></view><view a:for="{{p}}" a:for-item="item" a:key="m" class="content-card data-v-0932422e" onTap="{{item.n}}"><view class="cc-top data-v-0932422e"><view class="cc-tags data-v-0932422e"><text class="cc-tag data-v-0932422e">{{item.a}}</text><text class="cc-time data-v-0932422e">{{item.b}}</text></view><text class="cc-arrow data-v-0932422e">›</text></view><text class="cc-text data-v-0932422e">{{item.c}}{{item.d}}</text><view a:if="{{item.e}}" class="cc-images data-v-0932422e"><image a:for="{{item.f}}" a:for-item="img" a:key="a" src="{{img.b}}" mode="aspectFill" class="cc-thumb data-v-0932422e"/><text a:if="{{item.g}}" class="cc-more data-v-0932422e">+{{item.h}}</text></view><view class="cc-stats data-v-0932422e"><view class="cc-stat data-v-0932422e"><text class="cs-num data-v-0932422e">{{item.i}}</text><text class="cs-lbl data-v-0932422e">阅读</text></view><view class="cc-stat data-v-0932422e"><text class="cs-num data-v-0932422e">{{item.j}}</text><text class="cs-lbl data-v-0932422e">预约</text></view><view class="cc-stat accent data-v-0932422e"><text class="cs-num data-v-0932422e">¥{{item.k}}</text><text class="cs-lbl data-v-0932422e">收益</text></view><view class="cc-stat data-v-0932422e"><text class="cs-num track data-v-0932422e">{{item.l}}</text><text class="cs-lbl data-v-0932422e">追踪码</text></view></view></view></view></view>