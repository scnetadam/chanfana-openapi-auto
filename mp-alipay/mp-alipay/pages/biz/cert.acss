.cert-page.data-v-66614afc{min-height:100vh;background:#f0f2f5}.header.data-v-66614afc{padding:60rpx 30rpx 40rpx;background:linear-gradient(135deg,#2563eb,#1d4ed8);color:#fff}.title.data-v-66614afc{display:block;font-size:44rpx;font-weight:700;margin-bottom:10rpx}.subtitle.data-v-66614afc{font-size:26rpx;opacity:.9}.status-card.data-v-66614afc{display:flex;flex-direction:column;align-items:center;padding:80rpx 40rpx;margin:24rpx;background:#fff;border-radius:24rpx;box-shadow:0 4rpx 16rpx rgba(0,0,0,.06)}.status-card.pending .status-icon.data-v-66614afc{color:#f59e0b}.status-card.approved .status-icon.data-v-66614afc{color:#10b981}.status-card.rejected .status-icon.data-v-66614afc{color:#ef4444}.status-icon.data-v-66614afc{font-size:80rpx;margin-bottom:20rpx}.status-title.data-v-66614afc{font-size:36rpx;font-weight:700;color:#1f2937;margin-bottom:16rpx}.status-desc.data-v-66614afc{font-size:28rpx;color:#6b7280;text-align:center;line-height:1.6;margin-bottom:30rpx}.action-btn.data-v-66614afc{padding:0 60rpx;height:80rpx;line-height:80rpx;font-size:28rpx;font-weight:600;color:#fff;background:linear-gradient(135deg,#2563eb,#1d4ed8);border-radius:40rpx}.action-btn.data-v-66614afc:after{border:none}.form-section.data-v-66614afc{padding:24rpx}.form-group.data-v-66614afc{margin-bottom:30rpx}.form-label.data-v-66614afc{display:block;font-size:28rpx;color:#1f2937;margin-bottom:12rpx}.form-label.required.data-v-66614afc:before{content:"*";color:#ef4444;margin-right:4rpx}.form-input.data-v-66614afc{width:100%;height:88rpx;padding:0 24rpx;font-size:28rpx;color:#1f2937;background:#fff;border:2rpx solid #e5e7eb;border-radius:12rpx}.form-picker.data-v-66614afc{display:flex;align-items:center;justify-content:space-between;height:88rpx;padding:0 24rpx;background:#fff;border:2rpx solid #e5e7eb;border-radius:12rpx}.form-picker .placeholder.data-v-66614afc{color:#9ca3af}.form-picker .picker-arrow.data-v-66614afc{font-size:32rpx;color:#d1d5db}.submit-btn.data-v-66614afc{width:100%;height