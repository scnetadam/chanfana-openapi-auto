.stats-page.data-v-d8014f0a{min-height:100vh;background:#f0f2f5;padding-bottom:40rpx}.header.data-v-d8014f0a{padding:30rpx;background:#fff}.title.data-v-d8014f0a{font-size:36rpx;font-weight:700;color:#1f2937}.overview.data-v-d8014f0a{padding:24rpx}.stat-card.data-v-d8014f0a{background:#fff;border-radius:16rpx;padding:30rpx;text-align:center}.stat-card.large.data-v-d8014f0a{margin-bottom:16rpx;background:linear-gradient(135deg,#2563eb,#1d4ed8);color:#fff}.stat-value.data-v-d8014f0a{display:block;font-size:48rpx;font-weight:700;margin-bottom:8rpx}.stat-label.data-v-d8014f0a{font-size:24rpx;opacity:.8}.stat-row.data-v-d8014f0a{display:grid;grid-template-columns:repeat(3,1fr);gap:16rpx}.section.data-v-d8014f0a{padding:0 24rpx;margin-top:24rpx}.section-title.data-v-d8014f0a{display:block;font-size:32rpx;font-weight:700;color:#1f2937;margin-bottom:20rpx}.rank-list.data-v-d8014f0a{background:#fff;border-radius:20rpx;overflow:hidden}.rank-item.data-v-d8014f0a{display:flex;align-items:center;padding:30rpx;border-bottom:2rpx solid #f3f4f6}.rank-item.data-v-d8014f0a:last-child{border-bottom:none}.rank-num.data-v-d8014f0a{width:48rpx;height:48rpx;background:#eff6ff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:24rpx;font-weight:700;color:#2563eb;margin-right:16rpx}.rank-name.data-v-d8014f0a{flex:1;font-size:28rpx;color:#1f2937}.rank-stats.data-v-d8014f0a{display:flex;gap:16rpx;font-size:24rpx;color:#9ca3af}