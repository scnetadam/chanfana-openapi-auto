.task-page.data-v-3a8ebdb2{min-height:100vh;background:#f0f2f5}.header.data-v-3a8ebdb2{display:flex;align-items:center;justify-content:space-between;padding:30rpx;background:#fff}.title.data-v-3a8ebdb2{font-size:36rpx;font-weight:700;color:#1f2937}.create-btn.data-v-3a8ebdb2{padding:0 24rpx;height:64rpx;line-height:64rpx;font-size:26rpx;font-weight:600;color:#fff;background:linear-gradient(135deg,#10b981,#059669);border-radius:32rpx}.create-btn.data-v-3a8ebdb2:after{border:none}.tabs.data-v-3a8ebdb2{display:flex;background:#fff;border-bottom:2rpx solid #f3f4f6}.tab.data-v-3a8ebdb2{flex:1;display:flex;align-items:center;justify-content:center;height:88rpx;font-size:28rpx;color:#6b7280;position:relative}.tab.active.data-v-3a8ebdb2{color:#2563eb;font-weight:600}.tab.active.data-v-3a8ebdb2:after{content:"";position:absolute;bottom:0;left:50%;transform:translate(-50%);width:60rpx;height:4rpx;background:#2563eb;border-radius:2rpx}.loading.data-v-3a8ebdb2{display:flex;align-items:center;justify-content:center;padding:120rpx;color:#9ca3af}.task-list.data-v-3a8ebdb2{padding:24rpx}.task-card.data-v-3a8ebdb2{padding:30rpx;margin-bottom:20rpx;background:#fff;border-radius:20rpx}.task-header.data-v-3a8ebdb2{display:flex;align-items:center;justify-content:space-between;margin-bottom:16rpx}.task-type.data-v-3a8ebdb2{padding:6rpx 16rpx;background:#f3f4f6;border-radius:8rpx;font-size:24rpx;color:#6b7280}.task-reward.data-v-3a8ebdb2{font-size:28rpx;font-weight:700;color:#f59e0b}.task-title.data-v-3a8ebdb2{display:block;font-size:32rpx;font-weight:600;color:#1f2937;margin-bottom:20rpx}.progress-row.data-v-3a8ebdb2{display:flex;align-items:center;gap:16rpx;margin-bottom:20rpx}.progress-label.data-v-3a8ebdb2{font-size:24rpx;color:#6b7280}.progress-bar.data-v-3a8ebdb2{flex:1;height:8rpx;background:#f3f4f6;border-radius:4rpx}.progress-fill.data-v-3a8ebdb2{height:100%;background:#10b981;border-radius:4rpx}.progress-text.data-v-3a8ebdb2{font-size:24rpx;color:#6b7280}.submissions.data-v-3a8ebdb2{padding-top:20rpx;border-top:2rpx solid #f3f4f6}.submissions-title.data-v-3a8ebdb2{display:block;font-size:26rpx;color:#9ca3af;margin-bottom:16rpx}.submission-item.data-v-3a8ebdb2{display:flex;align-items:center;padding:20rpx;background:#f9fafb;border-radius:12rpx;margin-bottom:12rpx}.sub-name.data-v-3a8ebdb2{flex:1;font-size:28rpx;color:#1f2937}.sub-time.data-v-3a8ebdb2{font-size:24rpx;color:#9ca3af;margin-right:20rpx}.sub-action.data-v-3a8ebdb2{font-size:26rpx;color:#2563eb}