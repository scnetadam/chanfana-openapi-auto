<view class="task-page data-v-3a8ebdb2"><view class="header data-v-3a8ebdb2"><text class="title data-v-3a8ebdb2">KOL任务管理</text><button class="create-btn data-v-3a8ebdb2" onTap="{{a}}"><text class="data-v-3a8ebdb2">+ 发布任务</text></button></view><view class="tabs data-v-3a8ebdb2"><view class="{{('tab') + ' ' + 'data-v-3a8ebdb2' + ' ' + (b && 'active')}}" onTap="{{c}}"><text class="data-v-3a8ebdb2">进行中</text></view><view class="{{('tab') + ' ' + 'data-v-3a8ebdb2' + ' ' + (d && 'active')}}" onTap="{{e}}"><text class="data-v-3a8ebdb2">待审核</text></view><view class="{{('tab') + ' ' + 'data-v-3a8ebdb2' + ' ' + (f && 'active')}}" onTap="{{g}}"><text class="data-v-3a8ebdb2">已完成</text></view></view><view a:if="{{h}}" class="loading data-v-3a8ebdb2"><text class="data-v-3a8ebdb2">加载中...</text></view><view a:else class="task-list data-v-3a8ebdb2"><view a:for="{{i}}" a:for-item="task" a:key="i" class="task-card data-v-3a8ebdb2"><view class="task-header data-v-3a8ebdb2"><view class="task-type data-v-3a8ebdb2">{{task.a}}</view><view class="task-reward data-v-3a8ebdb2">¥{{task.b}}/单</view></view><text class="task-title data-v-3a8ebdb2">{{task.c}}</text><view class="progress-row data-v-3a8ebdb2"><text class="progress-label data-v-3a8ebdb2">完成进度</text><view class="progress-bar data-v-3a8ebdb2"><view class="progress-fill data-v-3a8ebdb2" style="{{'width:' + task.d}}"/></view><text class="progress-text data-v-3a8ebdb2">{{task.e}}/{{task.f}}</text></view><view a:if="{{task.g}}" class="submissions data-v-3a8ebdb2"><text class="submissions-title data-v-3a8ebdb2">待审核提交</text><view a:for="{{task.h}}" a:for-item="sub" a:key="c" class="submission-item data-v-3a8ebdb2" onTap="{{sub.d}}"><text class="sub-name data-v-3a8ebdb2">{{sub.a}}</text><text class="sub-time data-v-3a8ebdb2">{{sub.b}}</text><text class="sub-action data-v-3a8ebdb2">审核 ›</text></view></view></view></view></view>