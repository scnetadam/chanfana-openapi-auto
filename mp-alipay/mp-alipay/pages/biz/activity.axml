<view class="activity-page data-v-7ca4aeff"><view class="header data-v-7ca4aeff"><text class="title data-v-7ca4aeff">活动管理</text><button class="create-btn data-v-7ca4aeff" onTap="{{a}}"><text class="data-v-7ca4aeff">+ 创建活动</text></button></view><view a:if="{{b}}" class="loading data-v-7ca4aeff"><text class="data-v-7ca4aeff">加载中...</text></view><view a:else class="activity-list data-v-7ca4aeff"><view a:for="{{c}}" a:for-item="act" a:key="o" class="activity-card data-v-7ca4aeff"><view class="card-header data-v-7ca4aeff"><view class="brand-tag data-v-7ca4aeff">{{act.a}}</view><view class="status-tag data-v-7ca4aeff" style="{{'background:' + act.c + ';' + ('color:' + act.d)}}">{{act.b}}</view></view><text class="model data-v-7ca4aeff">{{act.e}}</text><text class="title data-v-7ca4aeff">{{act.f}}</text><view class="stats-row data-v-7ca4aeff"><view class="stat-item data-v-7ca4aeff"><text class="stat-value data-v-7ca4aeff">{{act.g}}</text><text class="stat-label data-v-7ca4aeff">浏览</text></view><view class="stat-item data-v-7ca4aeff"><text class="stat-value data-v-7ca4aeff">{{act.h}}</text><text class="stat-label data-v-7ca4aeff">预约</text></view><view class="stat-item data-v-7ca4aeff"><text class="stat-value data-v-7ca4aeff">¥{{act.i}}</text><text class="stat-label data-v-7ca4aeff">奖励</text></view></view><view class="budget-row data-v-7ca4aeff"><text class="budget-label data-v-7ca4aeff">预算消耗</text><view class="budget-bar data-v-7ca4aeff"><view class="budget-fill data-v-7ca4aeff" style="{{'width:' + act.j}}"/></view><text class="budget-text data-v-7ca4aeff"> ¥{{act.k}} / ¥{{act.l}}</text></view><view class="card-actions data-v-7ca4aeff"><button class="action-btn data-v-7ca4aeff" onTap="{{act.m}}">编辑</button><button class="action-btn primary data-v-7ca4aeff" onTap="{{act.n}}">查看数据</button></view></view></view><view a:if="{{d}}" class="create-modal data-v-7ca4aeff"><view class="modal-mask data-v-7ca4aeff" onTap="{{e}}"></view><view class="modal-content data-v-7ca4aeff"><view class="modal-header data-v-7ca4aeff"><text class="modal-title data-v-7ca4aeff">创建推广活动</text><text class="modal-close data-v-7ca4aeff" onTap="{{f}}">✕</text></view><scroll-view class="modal-body data-v-7ca4aeff" scroll-y><view class="form-group data-v-7ca4aeff"><text class="form-label required data-v-7ca4aeff">品牌</text><input class="form-input data-v-7ca4aeff" placeholder="如：小米汽车" value="{{g}}" onInput="{{h}}"/></view><view class="form-group data-v-7ca4aeff"><text class="form-label required data-v-7ca4aeff">车型</text><input class="form-input data-v-7ca4aeff" placeholder="如：SU7" value="{{i}}" onInput="{{j}}"/></view><view class="form-group data-v-7ca4aeff"><text class="form-label required data-v-7ca4aeff">活动标题</text><input class="form-input data-v-7ca4aeff" placeholder="请输入活动标题" value="{{k}}" onInput="{{l}}"/></view><view class="form-group data-v-7ca4aeff"><text class="form-label data-v-7ca4aeff">活动描述</text><textarea class="form-textarea data-v-7ca4aeff" placeholder="请输入活动描述" value="{{m}}" onInput="{{n}}"/></view><view class="form-group data-v-7ca4aeff"><text class="form-label required data-v-7ca4aeff">浏览奖励（元）</text><input class="form-input data-v-7ca4aeff" type="digit" placeholder="0.01" value="{{o}}" onInput="{{p}}"/></view><view class="form-group data-v-7ca4aeff"><text class="form-label required data-v-7ca4aeff">试驾奖励（元）</text><input class="form-input data-v-7ca4aeff" type="number" placeholder="50" value="{{q}}" onInput="{{r}}"/></view><view class="form-group data-v-7ca4aeff"><text class="form-label required data-v-7ca4aeff">预算总额（元）</text><input class="form-input data-v-7ca4aeff" type="number" placeholder="10000" value="{{s}}" onInput="{{t}}"/></view></scroll-view><view class="modal-footer data-v-7ca4aeff"><button class="cancel-btn data-v-7ca4aeff" onTap="{{v}}">取消</button><button class="confirm-btn data-v-7ca4aeff" onTap="{{w}}">创建</button></view></view></view></view>