<view class="cert-page data-v-66614afc"><view class="header data-v-66614afc"><text class="title data-v-66614afc">商家认证</text><text class="subtitle data-v-66614afc">完成认证解锁全部商家功能</text></view><view a:if="{{a}}" class="status-card pending data-v-66614afc"><text class="status-icon data-v-66614afc">⏳</text><text class="status-title data-v-66614afc">审核中</text><text class="status-desc data-v-66614afc">您的认证申请正在审核中，预计1-3个工作日完成</text></view><view a:elif="{{b}}" class="status-card approved data-v-66614afc"><text class="status-icon data-v-66614afc">✅</text><text class="status-title data-v-66614afc">认证通过</text><text class="status-desc data-v-66614afc">您已成为认证商家，可使用全部商家功能</text><button class="action-btn data-v-66614afc" onTap="{{c}}">返回工作台</button></view><view a:elif="{{d}}" class="status-card rejected data-v-66614afc"><text class="status-icon data-v-66614afc">❌</text><text class="status-title data-v-66614afc">认证失败</text><text class="status-desc data-v-66614afc">{{e}}</text><button class="action-btn data-v-66614afc" onTap="{{f}}">重新申请</button></view><view a:else class="form-section data-v-66614afc"><view class="form-group data-v-66614afc"><text class="form-label required data-v-66614afc">公司名称</text><input class="form-input data-v-66614afc" placeholder="请输入公司全称" value="{{g}}" onInput="{{h}}"/></view><view class="form-group data-v-66614afc"><text class="form-label data-v-66614afc">统一社会信用代码</text><input class="form-input data-v-66614afc" placeholder="请输入18位信用代码" maxlength="18" value="{{i}}" onInput="{{j}}"/></view><view class="form-group data-v-66614afc"><text class="form-label data-v-66614afc">法人代表</text><input class="form-input data-v-66614afc" placeholder="请输入法人姓名" value="{{k}}" onInput="{{l}}"/></view><view class="form-group data-v-66614afc"><text class="form-label required data-v-66614afc">联系人</text><input class="form-input data-v-66614afc" placeholder="请输入联系人姓名" value="{{m}}" onInput="{{n}}"/></view><view class="form-group data-v-66614afc"><text class="form-label required data-v-66614afc">联系电话</text><input class="form-input data-v-66614afc" placeholder="请输入手机号" type="tel" maxlength="11" value="{{o}}" onInput="{{p}}"/></view><view class="form-group data-v-66614afc"><text class="form-label data-v-66614afc">所属行业</text><picker class="data-v-66614afc" value="{{s}}" range="{{t}}" onChange="{{v}}"><view class="form-picker data-v-66614afc"><text class="{{('data-v-66614afc') + ' ' + (r && 'placeholder')}}">{{q}}</text><text class="picker-arrow data-v-66614afc">›</text></view></picker></view><view class="form-group data-v-66614afc"><text class="form-label data-v-66614afc">企业规模</text><picker class="data-v-66614afc" value="{{y}}" range="{{z}}" onChange="{{A}}"><view class="form-picker data-v-66614afc"><text class="{{('data-v-66614afc') + ' ' + (x && 'placeholder')}}">{{w}}</text><text class="picker-arrow data-v-66614afc">›</text></view></picker></view><button class="submit-btn data-v-66614afc" loading="{{B}}" disabled="{{C}}" onTap="{{D}}"> 提交认证 </button></view></view>