<view class="settlement-page data-v-fc41c016"><view class="header data-v-fc41c016"><text class="title data-v-fc41c016">结算管理</text></view><view class="settlement-list data-v-fc41c016"><view a:for="{{a}}" a:for-item="item" a:key="h" class="settlement-card data-v-fc41c016"><view class="card-header data-v-fc41c016"><text class="user-name data-v-fc41c016">{{item.a}}</text><view class="{{('status-tag') + ' ' + 'data-v-fc41c016' + ' ' + item.c}}">{{item.b}}</view></view><view class="card-body data-v-fc41c016"><text class="amount data-v-fc41c016">¥{{item.d}}</text><text class="time data-v-fc41c016">{{item.e}}</text></view><button a:if="{{item.f}}" class="action-btn data-v-fc41c016" onTap="{{item.g}}"> 确认结算 </button></view></view></view>