<view class="content-gen-page data-v-65c5998a"><view class="header data-v-65c5998a"><text class="title data-v-65c5998a">✍️ 智能内容生成</text><text class="subtitle data-v-65c5998a">AI生成多风格汽车文案</text></view><view class="form-section data-v-65c5998a"><view class="form-group data-v-65c5998a"><text class="form-label required data-v-65c5998a">品牌</text><input class="form-input data-v-65c5998a" placeholder="如：小米汽车" value="{{a}}" onInput="{{b}}"/></view><view class="form-group data-v-65c5998a"><text class="form-label required data-v-65c5998a">车型</text><input class="form-input data-v-65c5998a" placeholder="如：SU7" value="{{c}}" onInput="{{d}}"/></view><view class="form-group data-v-65c5998a"><text class="form-label data-v-65c5998a">关键词</text><input class="form-input data-v-65c5998a" placeholder="如：续航、智能、性能（可选）" value="{{e}}" onInput="{{f}}"/></view><view class="form-group data-v-65c5998a"><text class="form-label data-v-65c5998a">文案风格</text><view class="style-grid data-v-65c5998a"><view a:for="{{g}}" a:for-item="s" a:key="c" class="{{('style-item') + ' ' + 'data-v-65c5998a' + ' ' + (s.d && 'active')}}" onTap="{{s.e}}"><text class="style-icon data-v-65c5998a">{{s.a}}</text><text class="style-label data-v-65c5998a">{{s.b}}</text></view></view></view><button class="generate-btn data-v-65c5998a" loading="{{h}}" disabled="{{i}}" onTap="{{j}}"><text class="btn-icon data-v-65c5998a">✨</text><text class="data-v-65c5998a">AI生成</text></button></view><view a:if="{{k}}" class="result-section data-v-65c5998a"><text class="section-title data-v-65c5998a">生成结果（{{l}}个版本）</text><view a:for="{{m}}" a:for-item="draft" a:key="f" class="draft-card data-v-65c5998a"><view class="draft-header data-v-65c5998a"><text class="draft-style data-v-65c5998a">{{draft.a}}</text><text class="draft-num data-v-65c5998a">版本 {{draft.b}}</text></view><text class="draft-text data-v-65c5998a">{{draft.c}}</text><view class="draft-actions data-v-65c5998a"><button class="action-btn copy data-v-65c5998a" onTap="{{draft.d}}"><text class="data-v-65c5998a">复制</text></button><button class="action-btn use data-v-65c5998a" onTap="{{draft.e}}"><text class="data-v-65c5998a">使用</text></button></view></view></view><view a:elif="{{n}}" class="empty-result data-v-65c5998a"><text class="empty-icon data-v-65c5998a">📭</text><text class="empty-text data-v-65c5998a">暂无生成结果</text></view></view>