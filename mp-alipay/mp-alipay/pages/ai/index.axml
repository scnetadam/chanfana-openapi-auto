<view class="ai-app-page data-v-0fa48534"><view class="header data-v-0fa48534"><view class="header-bg data-v-0fa48534"></view><view class="header-content data-v-0fa48534"><text class="title data-v-0fa48534">🤖 AI应用中心</text><text class="subtitle data-v-0fa48534">智能赋能 · 效率倍增</text></view></view><view class="quick-actions data-v-0fa48534"><view class="quick-item data-v-0fa48534" onTap="{{a}}"><view class="quick-icon data-v-0fa48534" style="background:linear-gradient(135deg, #2563eb, #1d4ed8)"><text class="data-v-0fa48534">✍️</text></view><text class="quick-text data-v-0fa48534">快速生成</text></view><view class="quick-item data-v-0fa48534" onTap="{{b}}"><view class="quick-icon data-v-0fa48534" style="background:linear-gradient(135deg, #10b981, #059669)"><text class="data-v-0fa48534">🤖</text></view><text class="quick-text data-v-0fa48534">AI助手</text></view></view><view class="section data-v-0fa48534"><text class="section-title data-v-0fa48534">AI应用</text><view class="app-grid data-v-0fa48534"><view a:for="{{c}}" a:for-item="app" a:key="f" class="app-card data-v-0fa48534" onTap="{{app.g}}"><view class="app-icon data-v-0fa48534" style="{{'background:' + app.b}}"><text class="data-v-0fa48534">{{app.a}}</text></view><text class="app-name data-v-0fa48534">{{app.c}}</text><text class="app-desc data-v-0fa48534">{{app.d}}</text><text class="app-stats data-v-0fa48534">{{app.e}}</text></view></view></view><view class="section data-v-0fa48534"><text class="section-title data-v-0fa48534">最近使用</text><view class="usage-list data-v-0fa48534"><view a:for="{{d}}" a:for-item="item" a:key="d" class="usage-item data-v-0fa48534"><text class="usage-time data-v-0fa48534">{{item.a}}</text><text class="usage-action data-v-0fa48534">{{item.b}}</text><text class="usage-result data-v-0fa48534">{{item.c}}</text></view></view></view><view class="section data-v-0fa48534"><text class="section-title data-v-0fa48534">AI能力统计</text><view class="stats-grid data-v-0fa48534"><view class="stat-card data-v-0fa48534"><text class="stat-value data-v-0fa48534">6,640</text><text class="stat-label data-v-0fa48534">总调用次数</text></view><view class="stat-card data-v-0fa48534"><text class="stat-value data-v-0fa48534">98.5%</text><text class="stat-label data-v-0fa48534">成功率</text></view><view class="stat-card data-v-0fa48534"><text class="stat-value data-v-0fa48534">1.2s</text><text class="stat-label data-v-0fa48534">平均响应</text></view></view></view></view>