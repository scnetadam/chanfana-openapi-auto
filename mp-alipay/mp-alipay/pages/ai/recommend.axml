<view class="recommend-page data-v-9afcb550"><view class="header data-v-9afcb550"><text class="title data-v-9afcb550">🎯 智能推荐</text><text class="subtitle data-v-9afcb550">活动KOL智能匹配</text></view><view a:if="{{a}}" class="loading data-v-9afcb550"><text class="data-v-9afcb550">匹配中...</text></view><view a:else class="recommend-list data-v-9afcb550"><view a:for="{{b}}" a:for-item="rec" a:key="f" class="recommend-card data-v-9afcb550"><view class="rec-header data-v-9afcb550"><text class="rec-brand data-v-9afcb550">{{rec.a}}</text><text class="rec-model data-v-9afcb550">{{rec.b}}</text></view><text class="rec-reason data-v-9afcb550">{{rec.c}}</text><view class="rec-footer data-v-9afcb550"><view class="confidence data-v-9afcb550"><text class="confidence-label data-v-9afcb550">匹配度</text><text class="confidence-value data-v-9afcb550">{{rec.d}}%</text></view><button class="rec-btn data-v-9afcb550" onTap="{{rec.e}}">查看活动</button></view></view></view></view>