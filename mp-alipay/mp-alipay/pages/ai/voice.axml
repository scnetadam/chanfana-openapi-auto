<view class="voice-page data-v-94464279"><view class="header data-v-94464279"><text class="title data-v-94464279">🎙️ AI语音</text><text class="subtitle data-v-94464279">语音识别 · 语音合成 · 实时翻译</text></view><view class="mode-tabs data-v-94464279"><view a:for="{{a}}" a:for-item="mode" a:key="c" class="{{('mode-tab') + ' ' + 'data-v-94464279' + ' ' + (mode.d && 'active')}}" onTap="{{mode.e}}"><text class="mode-icon data-v-94464279">{{mode.a}}</text><text class="mode-label data-v-94464279">{{mode.b}}</text></view></view><view a:if="{{b}}" class="recognition-section data-v-94464279"><view class="record-area data-v-94464279"><view class="{{('record-btn') + ' ' + 'data-v-94464279' + ' ' + (d && 'recording')}}" onTouchStart="{{e}}" onTouchEnd="{{f}}"><text class="record-icon data-v-94464279">{{c}}</text></view><text class="record-time data-v-94464279">{{g}}</text><text class="record-hint data-v-94464279">{{h}}</text></view><view a:if="{{i}}" class="result-area data-v-94464279"><text class="result-title data-v-94464279">识别结果</text><text class="result-text data-v-94464279">{{j}}</text><view class="result-actions data-v-94464279"><button class="action-btn data-v-94464279" onTap="{{k}}"><text class="data-v-94464279">复制</text></button><button class="action-btn primary data-v-94464279" onTap="{{l}}"><text class="data-v-94464279">使用</text></button></view></view></view><view a:elif="{{m}}" class="synthesis-section data-v-94464279"><view class="input-area data-v-94464279"><textarea class="text-input data-v-94464279" placeholder="请输入要合成的文字..." maxlength="200" value="{{n}}" onInput="{{o}}"/><text class="char-count data-v-94464279">{{p}}/200</text></view><button class="{{('play-btn') + ' ' + 'data-v-94464279' + ' ' + (s && 'playing')}}" disabled="{{t}}" onTap="{{v}}"><text class="play-icon data-v-94464279">{{q}}</text><text class="data-v-94464279">{{r}}</text></button><view class="voice-options data-v-94464279"><text class="option-title data-v-94464279">语音选项</text><view class="option-grid data-v-94464279"><view class="option-item active data-v-94464279"><text class="data-v-94464279">👩 女声</text></view><view class="option-item data-v-94464279"><text class="data-v-94464279">👨 男声</text></view><view class="option-item data-v-94464279"><text class="data-v-94464279">👧 童声</text></view></view></view></view><view a:else class="translation-section data-v-94464279"><view class="trans-input data-v-94464279"><textarea class="text-input data-v-94464279" placeholder="请输入或录音..." value="{{w}}" onInput="{{x}}"/></view><view class="lang-select data-v-94464279"><view class="lang-item active data-v-94464279"><text class="data-v-94464279">中文</text></view><text class="arrow data-v-94464279">→</text><view class="lang-item data-v-94464279"><text class="data-v-94464279">英文</text></view></view><button class="trans-btn data-v-94464279"><text class="data-v-94464279">开始翻译</text></button></view><view class="history-section data-v-94464279"><text class="section-title data-v-94464279">历史记录</text><view class="history-list data-v-94464279"><view a:for="{{y}}" a:for-item="item" a:key="d" class="history-item data-v-94464279"><text class="history-icon data-v-94464279">{{item.a}}</text><text class="history-text data-v-94464279">{{item.b}}</text><text class="history-time data-v-94464279">{{item.c}}</text></view></view></view></view>