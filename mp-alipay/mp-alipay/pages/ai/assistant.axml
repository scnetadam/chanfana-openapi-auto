<view class="assistant-page data-v-b68d6ac0"><view class="header data-v-b68d6ac0"><text class="title data-v-b68d6ac0">🤖 AI智能助手</text><text class="subtitle data-v-b68d6ac0">汽车知识问答顾问</text><button class="clear-btn data-v-b68d6ac0" onTap="{{a}}">清空对话</button></view><scroll-view class="chat-area data-v-b68d6ac0" scroll-y scroll-into-view="{{d}}" scroll-with-animation><view a:for="{{b}}" a:for-item="msg" a:key="c" id="{{msg.d}}" class="{{('message') + ' ' + 'data-v-b68d6ac0' + ' ' + msg.e}}"><view class="msg-avatar data-v-b68d6ac0"><text class="data-v-b68d6ac0">{{msg.a}}</text></view><view class="msg-content data-v-b68d6ac0"><text class="msg-text data-v-b68d6ac0">{{msg.b}}</text></view></view><view a:if="{{c}}" class="message assistant data-v-b68d6ac0"><view class="msg-avatar data-v-b68d6ac0"><text class="data-v-b68d6ac0">🤖</text></view><view class="msg-content data-v-b68d6ac0"><text class="msg-text typing data-v-b68d6ac0">正在思考中...</text></view></view></scroll-view><view class="quick-questions data-v-b68d6ac0"><text class="quick-title data-v-b68d6ac0">快捷问题</text><scroll-view class="quick-list data-v-b68d6ac0" scroll-x><view a:for="{{e}}" a:for-item="q" a:key="b" class="quick-item data-v-b68d6ac0" onTap="{{q.c}}"><text class="data-v-b68d6ac0">{{q.a}}</text></view></scroll-view></view><view class="input-area data-v-b68d6ac0"><input class="msg-input data-v-b68d6ac0" placeholder="输入您的问题..." disabled="{{f}}" confirm-type="send" onConfirm="{{g}}" value="{{h}}" onInput="{{i}}"/><button class="send-btn data-v-b68d6ac0" disabled="{{j}}" onTap="{{k}}"><text class="data-v-b68d6ac0">发送</text></button></view></view>