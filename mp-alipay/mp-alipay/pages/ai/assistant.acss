.assistant-page.data-v-b68d6ac0{display:flex;flex-direction:column;height:100vh;background:#f0f2f5}.header.data-v-b68d6ac0{position:relative;padding:30rpx;background:linear-gradient(135deg,#10b981,#059669);color:#fff}.title.data-v-b68d6ac0{display:block;font-size:36rpx;font-weight:700;margin-bottom:8rpx}.subtitle.data-v-b68d6ac0{font-size:24rpx;opacity:.9}.clear-btn.data-v-b68d6ac0{position:absolute;top:30rpx;right:30rpx;padding:0 20rpx;height:56rpx;line-height:56rpx;font-size:24rpx;background:rgba(255,255,255,.2);border-radius:28rpx;color:#fff}.clear-btn.data-v-b68d6ac0:after{border:none}.chat-area.data-v-b68d6ac0{flex:1;padding:20rpx;overflow-y:auto}.message.data-v-b68d6ac0{display:flex;margin-bottom:24rpx}.message.user.data-v-b68d6ac0{flex-direction:row-reverse}.message.user .msg-content.data-v-b68d6ac0{background:#2563eb;color:#fff}.message.assistant .msg-content.data-v-b68d6ac0{background:#fff;color:#1f2937}.msg-avatar.data-v-b68d6ac0{display:flex;align-items:center;justify-content:center;width:64rpx;height:64rpx;font-size:32rpx;flex-shrink:0}.msg-content.data-v-b68d6ac0{max-width:70%;padding:20rpx 24rpx;border-radius:20rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.05)}.msg-text.data-v-b68d6ac0{font-size:28rpx;line-height:1.6;word-break:break-all}.msg-text.typing.data-v-b68d6ac0{opacity:.6}.quick-questions.data-v-b68d6ac0{padding:20rpx;background:#fff;border-top:2rpx solid #f3f4f6}.quick-title.data-v-b68d6ac0{display:block;font-size:24rpx;color:#9ca3af;margin-bottom:12rpx}.quick-list.data-v-b68d6ac0{white-space:nowrap}.quick-item.data-v-b68d6ac0{display:inline-block;padding:12rpx 20rpx;margin-right:12rpx;background:#f3f4f6;border-radius:20rpx;font-size:24rpx;color:#6b7280}.input-area.data-v-b68d6ac0{display:flex;gap:16rpx;padding:20rpx;background:#fff;border-top:2rpx solid #f3f4f6;padding-bottom:calc(20rpx + env(safe-area-inset-bottom))}.msg-input.data-v-b68d6ac0{flex:1;height:80rpx;padding:0 24rpx;font-size:28rpx;background:#f9fafb;border:2rpx solid #e5e7eb;border-radius:40rpx}.send-btn.data-v-b68d6ac0{width:140rpx;height:80rpx;line-height:80rpx;font-size:28rpx;font-weight:600;color:#fff;background:linear-gradient(135deg,#10b981,#059669);border-radius:40rpx}.send-btn.data-v-b68d6ac0:after{border:none}.send-btn[disabled].data-v-b68d6ac0{opacity:.5}