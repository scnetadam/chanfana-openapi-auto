<view class="aivideo-page data-v-bf5ad7f4"><view class="header data-v-bf5ad7f4"><text class="title data-v-bf5ad7f4">🎬 AI视频生成</text><text class="subtitle data-v-bf5ad7f4">一键生成专业汽车视频</text></view><view class="tabs data-v-bf5ad7f4"><view class="{{('tab') + ' ' + 'data-v-bf5ad7f4' + ' ' + (a && 'active')}}" onTap="{{b}}"><text class="data-v-bf5ad7f4">模板库</text></view><view class="{{('tab') + ' ' + 'data-v-bf5ad7f4' + ' ' + (c && 'active')}}" onTap="{{d}}"><text class="data-v-bf5ad7f4">我的项目</text></view></view><view a:if="{{e}}" class="loading data-v-bf5ad7f4"><text class="data-v-bf5ad7f4">加载中...</text></view><view a:elif="{{f}}" class="template-grid data-v-bf5ad7f4"><view a:for="{{g}}" a:for-item="tmpl" a:key="h" class="template-card data-v-bf5ad7f4" onTap="{{tmpl.i}}"><view class="tmpl-icon data-v-bf5ad7f4">{{tmpl.a}}</view><text class="tmpl-name data-v-bf5ad7f4">{{tmpl.b}}</text><text class="tmpl-category data-v-bf5ad7f4">{{tmpl.c}}</text><text class="tmpl-desc data-v-bf5ad7f4">{{tmpl.d}}</text><view class="tmpl-meta data-v-bf5ad7f4"><text class="data-v-bf5ad7f4">{{tmpl.e}}秒</text><text class="data-v-bf5ad7f4">{{tmpl.f}}场景</text></view><view class="tmpl-features data-v-bf5ad7f4"><text a:for="{{tmpl.g}}" a:for-item="f" a:key="b" class="feature-tag data-v-bf5ad7f4">{{f.a}}</text></view></view></view><view a:else class="project-list data-v-bf5ad7f4"><view a:if="{{h}}" class="empty data-v-bf5ad7f4"><text class="empty-icon data-v-bf5ad7f4">📭</text><text class="empty-text data-v-bf5ad7f4">暂无项目</text><text class="empty-hint data-v-bf5ad7f4">选择模板创建第一个AI视频</text></view><block a:else><view a:for="{{i}}" a:for-item="proj" a:key="k" class="project-card data-v-bf5ad7f4"><view class="proj-header data-v-bf5ad7f4"><text class="proj-title data-v-bf5ad7f4">{{proj.a}}</text><view class="status-tag data-v-bf5ad7f4" style="{{'background:' + proj.c + ';' + ('color:' + proj.d)}}">{{proj.b}}</view></view><text class="proj-template data-v-bf5ad7f4">{{proj.e}}</text><view a:if="{{proj.f}}" class="progress-bar data-v-bf5ad7f4"><view class="progress-fill data-v-bf5ad7f4" style="{{'width:' + proj.g}}"></view></view><text a:if="{{proj.h}}" class="progress-text data-v-bf5ad7f4">{{proj.i}}%</text><view a:if="{{proj.j}}" class="proj-result data-v-bf5ad7f4"><text class="result-icon data-v-bf5ad7f4">✅</text><text class="result-text data-v-bf5ad7f4">视频已生成，点击查看</text></view></view></block></view><view a:if="{{j}}" class="create-modal data-v-bf5ad7f4"><view class="modal-mask data-v-bf5ad7f4" onTap="{{k}}"></view><view class="modal-content data-v-bf5ad7f4"><view class="modal-header data-v-bf5ad7f4"><text class="modal-title data-v-bf5ad7f4">创建AI视频</text><text class="modal-close data-v-bf5ad7f4" onTap="{{l}}">✕</text></view><view class="modal-body data-v-bf5ad7f4"><view a:if="{{m}}" class="selected-tmpl data-v-bf5ad7f4"><text class="tmpl-name data-v-bf5ad7f4">{{n}}</text><text class="tmpl-desc data-v-bf5ad7f4">{{o}}</text></view><view class="form-group data-v-bf5ad7f4"><text class="form-label data-v-bf5ad7f4">视频标题</text><input class="form-input data-v-bf5ad7f4" placeholder="请输入视频标题" value="{{p}}" onInput="{{q}}"/></view></view><view class="modal-footer data-v-bf5ad7f4"><button class="cancel-btn data-v-bf5ad7f4" onTap="{{r}}">取消</button><button class="confirm-btn data-v-bf5ad7f4" onTap="{{s}}">开始生成</button></view></view></view></view>