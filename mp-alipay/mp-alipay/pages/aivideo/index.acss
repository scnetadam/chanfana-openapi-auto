.aivideo-page.data-v-bf5ad7f4{min-height:100vh;background:#f0f2f5}.header.data-v-bf5ad7f4{padding:40rpx 30rpx;background:linear-gradient(135deg,#8b5cf6,#7c3aed);color:#fff}.title.data-v-bf5ad7f4{display:block;font-size:44rpx;font-weight:700;margin-bottom:10rpx}.subtitle.data-v-bf5ad7f4{font-size:26rpx;opacity:.9}.tabs.data-v-bf5ad7f4{display:flex;background:#fff;border-bottom:2rpx solid #f3f4f6}.tab.data-v-bf5ad7f4{flex:1;display:flex;align-items:center;justify-content:center;height:88rpx;font-size:28rpx;color:#6b7280;position:relative}.tab.active.data-v-bf5ad7f4{color:#8b5cf6;font-weight:600}.tab.active.data-v-bf5ad7f4:after{content:"";position:absolute;bottom:0;left:50%;transform:translate(-50%);width:60rpx;height:4rpx;background:#8b5cf6;border-radius:2rpx}.loading.data-v-bf5ad7f4{display:flex;align-items:center;justify-content:center;padding:120rpx;color:#9ca3af}.template-grid.data-v-bf5ad7f4{display:grid;grid-template-columns:repeat(2,1fr);gap:20rpx;padding:24rpx}.template-card.data-v-bf5ad7f4{padding:30rpx;background:#fff;border-radius:20rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.04)}.tmpl-icon.data-v-bf5ad7f4{font-size:60rpx;margin-bottom:16rpx}.tmpl-name.data-v-bf5ad7f4{display:block;font-size:30rpx;font-weight:600;color:#1f2937;margin-bottom:8rpx}.tmpl-category.data-v-bf5ad7f4{display:block;font-size:22rpx;color:#8b5cf6;margin-bottom:8rpx}.tmpl-desc.data-v-bf5ad7f4{display:block;font-size:24rpx;color:#6b7280;line-height:1.5;margin-bottom:16rpx}.tmpl-meta.data-v-bf5ad7f4{display:flex;gap:16rpx;margin-bottom:16rpx;font-size:22rpx;color:#9ca3af}.tmpl-features.data-v-bf5ad7f4{display:flex;flex-wrap:wrap;gap:8rpx}.feature-tag.data-v-bf5ad7f4{padding:4rpx 12rpx;background:#f3f4f6;border-radius:6rpx;font-size:20rpx;color:#6b7280}.project-list.data-v-bf5ad7f4{padding:24rpx}.empty.data-v-bf5ad7f4{display:flex;flex-direction:column;align-items:center;padding:120rpx 0}.empty-icon.data-v-bf5ad7f4{font-size:80rpx;margin-bottom:20rpx}.empty-text.data-v-bf5ad7f4{font-size:32rpx;font-weight:600;color:#6b7280;margin-bottom:10rpx}.empty-hint.data-v-bf5ad7f4{font-size:26rpx;color:#9ca3af}.project-card.data-v-bf5ad7f4{padding:30rpx;margin-bottom:20rpx;background:#fff;border-radius:20rpx}.proj-header.data-v-bf5ad7f4{display:flex;align-items:center;justify-content:space-between;margin-bottom:12rpx}.proj-title.data-v-bf5ad7f4{font-size:30rpx;font-weight:600;color:#1f2937}.status-tag.data-v-bf5ad7f4{padding:6rpx 16rpx;border-radius:8rpx;font-size:22rpx;font-weight:600}.proj-template.data-v-bf5ad7f4{display:block;font-size:24rpx;color:#9ca3af;margin-bottom:16rpx}.progress-bar.data-v-bf5ad7f4{height:8rpx;background:#f3f4f6;border-radius:4rpx;margin-bottom:8rpx}.progress-fill.data-v-bf5ad7f4{height:100%;background:linear-gradient(90deg,#8b5cf6,#7c3aed);border-radius:4rpx;transition:width .3s}.progress-text.data-v-bf5ad7f4{font-size:24rpx;color:#8b5cf6}.proj-result.data-v-bf5ad7f4{display:flex;align-items:center;gap:12rpx;padding:20rpx;background:#ecfdf5;border-radius:12rpx}.result-icon.data-v-bf5ad7f4{font-size:28rpx}.result-text.data-v-bf5ad7f4{font-size:26rpx;color:#10b981}.create-modal.data-v-bf5ad7f4{position:fixed;top:0;right:0;bottom:0;left:0;z-index:1000}.modal-mask.data-v-bf5ad7f4{position:absolute;top:0;right:0;bottom:0;left:0;background:rgba(0,0,0,.5)}.modal-content.data-v-bf5ad7f4{position:absolute;bottom:0;left:0;right:0;background:#fff;border-radius:32rpx 32rpx 0 0}.modal-header.data-v-bf5ad7f4{display:flex;align-items:center;justify-content:space-between;padding:30rpx;border-bottom:2rpx solid #f3f4f6}.modal-title.data-v-bf5ad7f4{font-size:32rpx;font-weight:700;color:#1f2937}.modal-close.data-v-bf5ad7f4{font-size:40rpx;color:#9ca3af}.modal-body.data-v-bf5ad7f4{padding:30rpx}.selected-tmpl.data-v-bf5ad7f4{padding:20rpx;background:#f9fafb;border-radius:12rpx;margin-bottom:24rpx}.form-group.data-v-bf5ad7f4{margin-bottom:24rpx}.form-label.data-v-bf5ad7f4{display:block;font-size:26rpx;color:#1f2937;margin-bottom:10rpx}.form-input.data-v-bf5