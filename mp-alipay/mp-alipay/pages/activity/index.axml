<view class="activity-page data-v-6ccea213"><view class="hero data-v-6ccea213"><view class="hero-content data-v-6ccea213"><text class="hero-title data-v-6ccea213">🚗 汽车资讯</text><text class="hero-desc data-v-6ccea213">执信购万物，分享真实体验让每次传播产生价值</text></view><view class="hero-illustration data-v-6ccea213"><text class="hero-emoji data-v-6ccea213">🏎️</text></view></view><view class="quick-entry data-v-6ccea213"><view class="entry-item data-v-6ccea213" onTap="{{a}}"><view class="entry-icon data-v-6ccea213" style="background:linear-gradient(135deg, #2563eb, #1d4ed8)"><text class="data-v-6ccea213">🏢</text></view><text class="entry-text data-v-6ccea213">商家后台</text></view><view class="entry-item data-v-6ccea213" onTap="{{b}}"><view class="entry-icon data-v-6ccea213" style="background:linear-gradient(135deg, #8b5cf6, #7c3aed)"><text class="data-v-6ccea213">🤖</text></view><text class="entry-text data-v-6ccea213">AI应用</text></view><view class="entry-item data-v-6ccea213" onTap="{{c}}"><view class="entry-icon data-v-6ccea213" style="background:linear-gradient(135deg, #ec4899, #db2777)"><text class="data-v-6ccea213">🎬</text></view><text class="entry-text data-v-6ccea213">AI视频</text></view><view class="entry-item data-v-6ccea213" onTap="{{d}}"><view class="entry-icon data-v-6ccea213" style="background:linear-gradient(135deg, #10b981, #059669)"><text class="data-v-6ccea213">📝</text></view><text class="entry-text data-v-6ccea213">发布内容</text></view></view><view class="banner-section data-v-6ccea213"><swiper class="banner-swiper data-v-6ccea213" indicator-dots autoplay circular interval="4000" duration="500" indicator-color="rgba(255,255,255,0.5)" indicator-active-color="#fff"><swiper-item a:for="{{e}}" a:for-item="banner" a:key="e" class="data-v-6ccea213" onTap="{{banner.f}}"><view class="banner-item data-v-6ccea213" style="{{'background:' + banner.d}}"><view class="banner-content data-v-6ccea213"><text class="banner-icon data-v-6ccea213">{{banner.a}}</text><view class="banner-text data-v-6ccea213"><text class="banner-title data-v-6ccea213">{{banner.b}}</text><text class="banner-desc data-v-6ccea213">{{banner.c}}</text></view></view></view></swiper-item></swiper></view><view a:if="{{f}}" class="skeleton-list data-v-6ccea213"><view a:for="{{g}}" a:for-item="i" a:key="a" class="skeleton-card data-v-6ccea213"><view class="sk-cover data-v-6ccea213"></view><view class="sk-body data-v-6ccea213"><view class="sk-line w-60 data-v-6ccea213"></view><view class="sk-line w-90 data-v-6ccea213"></view><view class="sk-line w-40 data-v-6ccea213"></view></view></view></view><view a:if="{{h}}" class="ai-recommend-section data-v-6ccea213"><view class="ai-rec-header data-v-6ccea213"><text class="ai-rec-title data-v-6ccea213">✨ AI 为你推荐</text><text class="ai-rec-sub data-v-6ccea213">基于你的推广表现智能匹配</text></view><view a:for="{{i}}" a:for-item="rec" a:key="e" class="ai-rec-card data-v-6ccea213" onTap="{{rec.f}}" hover-class="card-hover"><view class="arc-top data-v-6ccea213"><view class="arc-brand-tag data-v-6ccea213">{{rec.a}}</view><text class="arc-model data-v-6ccea213">{{rec.b}}</text></view><text class="arc-reason data-v-6ccea213">{{rec.c}}</text><view class="arc-footer data-v-6ccea213"><text class="arc-reward data-v-6ccea213">试驾¥{{rec.d}}</text><text class="arc-go data-v-6ccea213">立即参与 ›</text></view></view></view><view a:elif="{{j}}" class="ai-recommend-section data-v-6ccea213"><view class="ai-rec-loading data-v-6ccea213"><text class="data-v-6ccea213">✨ AI 推荐生成中...</text></view></view><block a:else><view a:for="{{k}}" a:for-item="act" a:key="m" class="activity-card data-v-6ccea213" onTap="{{act.n}}" hover-class="card-hover"><view class="card-cover data-v-6ccea213" style="background:linear-gradient(135deg,#1e40af,#3b82f6)"><view class="cover-badge data-v-6ccea213">{{act.a}}</view><text class="cover-model data-v-6ccea213">{{act.b}}</text><view class="{{('cover-status') + ' ' + 'data-v-6ccea213' + ' ' + act.d}}">{{act.c}}</view></view><view class="card-body data-v-6ccea213"><text class="card-title data-v-6ccea213">{{act.e}}</text><text class="card-desc data-v-6ccea213">{{act.f}}</text><view class="reward-row data-v-6ccea213"><view class="reward-tag view data-v-6ccea213"><text class="rt-icon data-v-6ccea213">👁️</text><text class="rt-label data-v-6ccea213">阅读</text><text class="rt-value data-v-6ccea213">¥{{act.g}}</text></view><view class="reward-tag booking data-v-6ccea213"><text class="rt-icon data-v-6ccea213">📋</text><text class="rt-label data-v-6ccea213">试驾预约</text><text class="rt-value data-v-6ccea213">¥{{act.h}}</text></view></view><view class="budget-row data-v-6ccea213"><text class="budget-label data-v-6ccea213">预算池</text><view class="budget-bar data-v-6ccea213"><view class="budget-fill data-v-6ccea213" style="{{'width:' + act.i + ';' + ('background-color:' + act.j)}}"/></view><text class="budget-text data-v-6ccea213" style="{{'color:' + act.l}}">{{act.k}}% </text></view></view><view class="card-footer data-v-6ccea213"><text class="participate-btn data-v-6ccea213">立即参与 ›</text></view></view></block><view a:if="{{l}}" class="empty-state data-v-6ccea213"><text class="empty-icon data-v-6ccea213">📭</text><text class="empty-text data-v-6ccea213">暂无推广活动</text><text class="empty-hint data-v-6ccea213">敬请期待</text></view></view>