<view class="activity-page data-v-627136c0"><view class="hero data-v-627136c0"><view class="hero-content data-v-627136c0"><text class="hero-title data-v-627136c0">🚗 推广活动</text><text class="hero-desc data-v-627136c0">分享真实体验，让每一次传播都产生价值</text></view><view class="hero-illustration data-v-627136c0"><text class="hero-emoji data-v-627136c0">🏎️</text></view></view><view a:if="{{a}}" class="skeleton-list data-v-627136c0"><view a:for="{{b}}" a:for-item="i" a:key="a" class="skeleton-card data-v-627136c0"><view class="sk-cover data-v-627136c0"></view><view class="sk-body data-v-627136c0"><view class="sk-line w-60 data-v-627136c0"></view><view class="sk-line w-90 data-v-627136c0"></view><view class="sk-line w-40 data-v-627136c0"></view></view></view></view><view a:if="{{c}}" class="ai-recommend-section data-v-627136c0"><view class="ai-rec-header data-v-627136c0"><text class="ai-rec-title data-v-627136c0">✨ AI 为你推荐</text><text class="ai-rec-sub data-v-627136c0">基于你的推广表现智能匹配</text></view><view a:for="{{d}}" a:for-item="rec" a:key="e" class="ai-rec-card data-v-627136c0" onTap="{{rec.f}}" hover-class="card-hover"><view class="arc-top data-v-627136c0"><view class="arc-brand-tag data-v-627136c0">{{rec.a}}</view><text class="arc-model data-v-627136c0">{{rec.b}}</text></view><text class="arc-reason data-v-627136c0">{{rec.c}}</text><view class="arc-footer data-v-627136c0"><text class="arc-reward data-v-627136c0">试驾¥{{rec.d}}</text><text class="arc-go data-v-627136c0">立即参与 ›</text></view></view></view><view a:elif="{{e}}" class="ai-recommend-section data-v-627136c0"><view class="ai-rec-loading data-v-627136c0"><text class="data-v-627136c0">✨ AI 推荐生成中...</text></view></view><block a:else><view a:for="{{f}}" a:for-item="act" a:key="m" class="activity-card data-v-627136c0" onTap="{{act.n}}" hover-class="card-hover"><view class="card-cover data-v-627136c0" style="background:linear-gradient(135deg,#1e40af,#3b82f6)"><view class="cover-badge data-v-627136c0">{{act.a}}</view><text class="cover-model data-v-627136c0">{{act.b}}</text><view class="{{('cover-status') + ' ' + 'data-v-627136c0' + ' ' + act.d}}">{{act.c}}</view></view><view class="card-body data-v-627136c0"><text class="card-title data-v-627136c0">{{act.e}}</text><text class="card-desc data-v-627136c0">{{act.f}}</text><view class="reward-row data-v-627136c0"><view class="reward-tag view data-v-627136c0"><text class="rt-icon data-v-627136c0">👁️</text><text class="rt-label data-v-627136c0">阅读</text><text class="rt-value data-v-627136c0">¥{{act.g}}</text></view><view class="reward-tag booking data-v-627136c0"><text class="rt-icon data-v-627136c0">📋</text><text class="rt-label data-v-627136c0">试驾预约</text><text class="rt-value data-v-627136c0">¥{{act.h}}</text></view></view><view class="budget-row data-v-627136c0"><text class="budget-label data-v-627136c0">预算池</text><view class="budget-bar data-v-627136c0"><view class="budget-fill data-v-627136c0" style="{{'width:' + act.i + ';' + ('background-color:' + act.j)}}"/></view><text class="budget-text data-v-627136c0" style="{{'color:' + act.l}}">{{act.k}}% </text></view></view><view class="card-footer data-v-627136c0"><text class="participate-btn data-v-627136c0">立即参与 ›</text></view></view></block><view a:if="{{g}}" class="empty-state data-v-627136c0"><text class="empty-icon data-v-627136c0">📭</text><text class="empty-text data-v-627136c0">暂无推广活动</text><text class="empty-hint data-v-627136c0">敬请期待</text></view></view>