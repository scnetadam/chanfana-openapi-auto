<view class="page data-v-eb72c3ac"><view class="header data-v-eb72c3ac"><text class="header-title data-v-eb72c3ac">KOL任务中心</text></view><view a:if="{{a}}" class="stats-row data-v-eb72c3ac"><view class="stat-item data-v-eb72c3ac"><text class="stat-val price data-v-eb72c3ac">¥{{b}}</text><text class="stat-lbl data-v-eb72c3ac">累计收益</text></view><view class="stat-item data-v-eb72c3ac"><text class="stat-val data-v-eb72c3ac">{{c}}</text><text class="stat-lbl data-v-eb72c3ac">完成任务</text></view><view class="stat-item data-v-eb72c3ac"><text class="stat-val accent data-v-eb72c3ac">{{d}}</text><text class="stat-lbl data-v-eb72c3ac">待结算</text></view></view><view class="tab-row data-v-eb72c3ac"><text class="{{('data-v-eb72c3ac') + ' ' + 'tab' + ' ' + e}}" onTap="{{f}}">可领任务</text><text class="{{('data-v-eb72c3ac') + ' ' + 'tab' + ' ' + g}}" onTap="{{h}}">我发布的</text></view><view a:if="{{i}}" class="loading data-v-eb72c3ac"><text class="data-v-eb72c3ac">加载中...</text></view><view a:elif="{{j}}" class="empty data-v-eb72c3ac"><text class="data-v-eb72c3ac">{{k}}</text></view><scroll-view a:else scroll-y class="task-list data-v-eb72c3ac"><view a:for="{{l}}" a:for-item="task" a:key="l" class="task-card data-v-eb72c3ac"><view class="task-header data-v-eb72c3ac"><text class="task-type data-v-eb72c3ac">{{task.a}}</text><text class="task-title data-v-eb72c3ac">{{task.b}}</text></view><text a:if="{{task.c}}" class="task-desc data-v-eb72c3ac">{{task.d}}</text><view class="task-footer data-v-eb72c3ac"><view class="task-reward data-v-eb72c3ac"><text class="reward-val data-v-eb72c3ac">¥{{task.e}}</text><text class="reward-lbl data-v-eb72c3ac">每单奖励</text></view><view class="task-progress-info data-v-eb72c3ac"><text class="progress-text data-v-eb72c3ac">{{task.f}}/{{task.g}}</text><text class="progress-lbl data-v-eb72c3ac">完成进度</text></view><view a:if="{{task.h}}" class="task-action data-v-eb72c3ac"><button class="accept-btn data-v-eb72c3ac" onTap="{{task.i}}">领取任务</button></view><view a:else class="task-status data-v-eb72c3ac"><text class="data-v-eb72c3ac">{{task.j}}</text></view></view><progress class="data-v-eb72c3ac" percent="{{task.k}}" stroke-width="4" activeColor="#10b981" backgroundColor="#e5e7eb"/></view></scroll-view></view>