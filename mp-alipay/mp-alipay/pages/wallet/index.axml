<view class="wallet-page data-v-beb2e8c6"><view class="balance-card data-v-beb2e8c6"><view class="bc-bg-pattern data-v-beb2e8c6"></view><view class="bc-content data-v-beb2e8c6"><text class="bc-label data-v-beb2e8c6">推广金余额</text><text class="bc-amount data-v-beb2e8c6">¥{{a}}</text><view class="bc-meta data-v-beb2e8c6"><view class="bc-meta-item data-v-beb2e8c6"><text class="bc-meta-icon data-v-beb2e8c6">⭐</text><text class="bc-meta-val data-v-beb2e8c6">{{b}}</text><text class="bc-meta-lbl data-v-beb2e8c6">口碑值</text></view><view class="bc-meta-divider data-v-beb2e8c6"></view><view class="bc-meta-item data-v-beb2e8c6"><text class="bc-meta-icon data-v-beb2e8c6">📊</text><text class="bc-meta-val data-v-beb2e8c6">{{c}}</text><text class="bc-meta-lbl data-v-beb2e8c6">交易笔数</text></view></view></view><button class="withdraw-btn data-v-beb2e8c6" onTap="{{d}}"><text class="data-v-beb2e8c6">提现</text></button></view><view class="summary data-v-beb2e8c6"><text class="summary-title data-v-beb2e8c6">收益概况</text><view class="summary-grid data-v-beb2e8c6"><view class="summary-item data-v-beb2e8c6"><view class="si-icon blue data-v-beb2e8c6"><text class="data-v-beb2e8c6">👁️</text></view><text class="si-label data-v-beb2e8c6">阅读收益</text><text class="si-value data-v-beb2e8c6">¥0.01/次</text></view><view class="summary-item data-v-beb2e8c6"><view class="si-icon gold data-v-beb2e8c6"><text class="data-v-beb2e8c6">📋</text></view><text class="si-label data-v-beb2e8c6">试驾预约</text><text class="si-value accent data-v-beb2e8c6">¥5.00/次</text></view><view class="summary-item data-v-beb2e8c6"><view class="si-icon gray data-v-beb2e8c6"><text class="data-v-beb2e8c6">💰</text></view><text class="si-label data-v-beb2e8c6">提现门槛</text><text class="si-value data-v-beb2e8c6">¥10.00</text></view><view class="summary-item data-v-beb2e8c6"><view class="si-icon gray data-v-beb2e8c6"><text class="data-v-beb2e8c6">⏱️</text></view><text class="si-label data-v-beb2e8c6">结算周期</text><text class="si-value data-v-beb2e8c6">T+3</text></view></view></view><view class="tx-section data-v-beb2e8c6"><view class="tx-header data-v-beb2e8c6"><text class="tx-title data-v-beb2e8c6">交易明细</text><text a:if="{{e}}" class="tx-count data-v-beb2e8c6">共 {{f}} 条</text></view><view a:if="{{g}}" class="empty-tx data-v-beb2e8c6"><text class="empty-icon data-v-beb2e8c6">📭</text><text class="data-v-beb2e8c6">暂无交易记录</text></view><view a:for="{{h}}" a:for-item="tx" a:key="f" class="tx-item data-v-beb2e8c6"><view class="tx-left data-v-beb2e8c6"><text class="tx-desc data-v-beb2e8c6">{{tx.a}}</text><text class="tx-time data-v-beb2e8c6">{{tx.b}}</text></view><view class="tx-right data-v-beb2e8c6"><text class="{{('data-v-beb2e8c6') + ' ' + 'tx-amount' + ' ' + tx.e}}">{{tx.c}}{{tx.d}}</text><text class="tx-unit data-v-beb2e8c6">CNY</text></view></view></view></view>