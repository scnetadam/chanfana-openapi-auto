<view class="page data-v-c0mp1ance"><view class="header data-v-c0mp1ance"><text class="header-title data-v-c0mp1ance">合同阈值配置</text><text class="header-sub data-v-c0mp1ance">合规阈值与模拟</text></view><view a:if="{{a}}" class="loading data-v-c0mp1ance"><text class="data-v-c0mp1ance">加载中...</text></view><view a:elif="{{c}}" class="empty data-v-c0mp1ance"><text class="data-v-c0mp1ance">暂无配置项</text></view><view a:else class="data-v-c0mp1ance"><view a:for="{{b}}" a:for-item="item" a:key="j" class="param-card data-v-c0mp1ance"><view class="param-name data-v-c0mp1ance">{{item.a}}</view><text class="param-desc data-v-c0mp1ance">{{item.b}}</text><view a:if="{{item.c}}" class="param-edit data-v-c0mp1ance"><input class="edit-input data-v-c0mp1ance" type="digit" value="{{item.d}}" onInput="{{item.e}}" /><button class="save-btn data-v-c0mp1ance" onTap="{{item.f}}">保存</button><button class="cancel-btn data-v-c0mp1ance" onTap="{{item.g}}">取消</button></view><view a:else class="param-value-row data-v-c0mp1ance"><text class="param-val data-v-c0mp1ance">{{item.h}}</text><button class="edit-btn data-v-c0mp1ance" onTap="{{item.i}}">编辑</button></view></view></view><view class="section data-v-c0mp1ance"><text class="section-title data-v-c0mp1ance">阈值模拟器</text><view class="sim-form data-v-c0mp1ance"><view class="form-group data-v-c0mp1ance"><text class="form-label data-v-c0mp1ance">用户ID</text><input class="form-input data-v-c0mp1ance" value="{{h}}" onInput="{{i}}" placeholder="输入用户ID" /></view><view class="form-group data-v-c0mp1ance"><text class="form-label data-v-c0mp1ance">金额</text><input class="form-input data-v-c0mp1ance" type="digit" value="{{j}}" onInput="{{k}}" placeholder="输入金额" /></view><button class="sim-btn data-v-c0mp1ance" loading="{{l}}" onTap="{{m}}">模拟计算</button><view a:if="{{n}}" class="sim-result data-v-c0mp1ance"><text class="sim-result-text data-v-c0mp1ance">{{n}}</text></view></view></view></view>