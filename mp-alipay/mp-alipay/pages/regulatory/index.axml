<view class="page data-v-c0mp1ance"><view class="header data-v-c0mp1ance"><text class="header-title data-v-c0mp1ance">监管看板</text><text class="header-sub data-v-c0mp1ance">合规监管状态监控</text></view><view a:if="{{a}}" class="loading data-v-c0mp1ance"><text class="data-v-c0mp1ance">加载中...</text></view><view a:elif="{{b}}" class="data-v-c0mp1ance"><view class="stats-grid data-v-c0mp1ance"><view class="stat-card data-v-c0mp1ance"><text class="status-dot {{c?'enabled':'disabled'}} data-v-c0mp1ance">{{b?'✓':'✗'}}</text><text class="stat-lbl data-v-c0mp1ance">TIPS税务</text></view><view class="stat-card data-v-c0mp1ance"><text class="status-dot {{e?'enabled':'disabled'}} data-v-c0mp1ance">{{d?'✓':'✗'}}</text><text class="stat-lbl data-v-c0mp1ance">e-CNY追溯</text></view><view class="stat-card data-v-c0mp1ance"><text class="status-dot {{g?'enabled':'disabled'}} data-v-c0mp1ance">{{f?'✓':'✗'}}</text><text class="stat-lbl data-v-c0mp1ance">金税对接</text></view><view class="stat-card data-v-c0mp1ance"><text class="status-dot {{i?'enabled':'disabled'}} data-v-c0mp1ance">{{h?'✓':'✗'}}</text><text class="stat-lbl data-v-c0mp1ance">白名单</text></view></view><view class="risk-card data-v-c0mp1ance"><text class="risk-label data-v-c0mp1ance">风险等级</text><text class="risk-val {{k}} data-v-c0mp1ance">{{j}}</text></view><view a:if="{{m}}" class="section data-v-c0mp1ance"><text class="section-title data-v-c0mp1ance">监管预警</text><view a:for="{{l}}" a:for-item="item" a:key="e" class="alert-card data-v-c0mp1ance"><view class="alert-top data-v-c0mp1ance"><text class="alert-title data-v-c0mp1ance">{{item.a}}</text><text class="alert-severity {{item.b}} data-v-c0mp1ance">{{item.c}}</text></view><text class="alert-date data-v-c0mp1ance">{{item.d}}</text></view></view></view><view a:else class="empty data-v-c0mp1ance"><text class="data-v-c0mp1ance">暂无监管数据</text></view></view>