<view class="page data-v-c0mp1ance"><view class="header data-v-c0mp1ance"><text class="header-title data-v-c0mp1ance">KOL轨道管理</text><text class="header-sub data-v-c0mp1ance">税务轨道与税率配置</text></view><view a:if="{{a}}" class="loading data-v-c0mp1ance"><text class="data-v-c0mp1ance">加载中...</text></view><view a:elif="{{b}}" class="data-v-c0mp1ance"><view class="track-card data-v-c0mp1ance"><view class="track-badge {{c}} data-v-c0mp1ance">{{b}}轨</view><view class="track-info data-v-c0mp1ance"><view class="track-row data-v-c0mp1ance"><text class="track-label data-v-c0mp1ance">税类型</text><text class="track-val data-v-c0mp1ance">{{d}}</text></view><view class="track-row data-v-c0mp1ance"><text class="track-label data-v-c0mp1ance">预扣税率</text><text class="track-val data-v-c0mp1ance">{{e}} ({{f}}%)</text></view></view></view><view class="section data-v-c0mp1ance"><text class="section-title data-v-c0mp1ance">轨道分布</text><view a:for="{{g}}" a:for-item="item" a:key="f" class="dist-bar data-v-c0mp1ance"><view class="dist-label data-v-c0mp1ance"><text class="dist-track {{item.d}} data-v-c0mp1ance">{{item.a}}轨</text><text class="dist-count data-v-c0mp1ance">{{item.b}}人 ({{item.c}}%)</text></view><view class="dist-track-bar data-v-c0mp1ance"><view class="dist-fill {{item.d}} data-v-c0mp1ance" style="width:{{item.e}}%"></view></view></view></view><view a:if="{{h}}" class="section data-v-c0mp1ance"><text class="section-title data-v-c0mp1ance">轨道变更</text><view class="reclassify-form data-v-c0mp1ance"><view class="track-btns data-v-c0mp1ance"><text class="{{('data-v-c0mp1ance') + ' ' + 'rc-btn' + ' ' + i}}" onTap="{{j}}">A轨</text><text class="{{('data-v-c0mp1ance') + ' ' + 'rc-btn' + ' ' + k}}" onTap="{{l}}">B轨</text><text class="{{('data-v-c0mp1ance') + ' ' + 'rc-btn' + ' ' + m}}" onTap="{{n}}">C轨</text></view><button class="reclassify-btn data-v-c0mp1ance" loading="{{o}}" onTap="{{p}}">申请变更</button></view></view></view><view a:else class="empty data-v-c0mp1ance"><text class="data-v-c0mp1ance">暂无轨道信息</text></view></view>