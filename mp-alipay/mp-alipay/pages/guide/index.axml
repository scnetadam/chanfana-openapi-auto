<view class="guide-page data-v-6ecd4a71"><swiper class="guide-swiper data-v-6ecd4a71" current="{{b}}" indicator-dots="{{false}}" autoplay="{{false}}" circular="{{false}}" onChange="{{c}}"><swiper-item a:for="{{a}}" a:for-item="page" a:key="e" class="data-v-6ecd4a71"><view class="guide-item data-v-6ecd4a71" style="{{'background:' + page.d}}"><view class="guide-content data-v-6ecd4a71"><text class="guide-icon data-v-6ecd4a71">{{page.a}}</text><text class="guide-title data-v-6ecd4a71">{{page.b}}</text><text class="guide-desc data-v-6ecd4a71">{{page.c}}</text></view></view></swiper-item></swiper><view class="guide-dots data-v-6ecd4a71"><view a:for="{{d}}" a:for-item="page" a:key="a" class="{{('dot') + ' ' + 'data-v-6ecd4a71' + ' ' + (page.b && 'active')}}"/></view><view class="guide-actions data-v-6ecd4a71"><text class="skip-btn data-v-6ecd4a71" onTap="{{e}}">跳过</text><button class="next-btn data-v-6ecd4a71" onTap="{{g}}">{{f}}</button></view></view>