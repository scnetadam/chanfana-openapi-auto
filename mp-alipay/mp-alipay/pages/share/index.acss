ff;border-radius:20rpx}.success-title.data-v-c7555b13{font-size:34rpx;font-weight:700;color:#1f2937;margin-bottom:12rpx}.success-desc.data-v-c7555b13{font-size:26rpx;color:#6b7280}.action-bar.data-v-c7555b13{position:fixed;left:0;right:0;bottom:0;display:flex;gap:16rpx;padding:20rpx 24rpx;background:#fff;box-shadow:0 -4rpx 24rpx rgba(0,0,0,.05);z-index:50}.action-btn.data-v-c7555b13{flex:1;height:88rpx;line-height:88rpx;font-size:30rpx;font-weight:600;border-radius:44rpx;text-align:center}.action-btn.share.data-v-c7555b13{color:#fff;background:linear-gradient(135deg,#2563eb,#1d4ed8)}.action-btn.copy.data-v-c7555b13{color:#2563eb;background:#eff6ff}.ai-fab.data-v-c7555b13{position:fixed;right:30rpx;bottom:200rpx;display:flex;flex-direction:column;align-items:center;gap:6rpx;z-index:100;padding:16rpx 20rpx;background:linear-gradient(135deg,#8b5cf6,#6366f1);border-radius:50rpx;box-shadow:0 6rpx 24rpx rgba(99,102,241,.4)}.ai-fab-icon.data-v-c7555b13{font-size:36rpx}.ai-fab-label.data-v-c7555b13{font-size:20rpx;color:#fff;font-weight:500}.ai-chat-panel.data-v-c7555b13{position:fixed;right:20rpx;bottom:140rpx;width:620rpx;max-height:700rpx;display:flex;flex-direction:column;background:#fff;border-radius:24rpx;box-shadow:0 12rpx 48rpx rgba(0,0,0,.15);z-index:200;overflow:hidden}.acp-header.data-v-c7555b13{display:flex;align-items:center;justify-content:space-between;padding:20rpx 24rpx;background:linear-gradient(135deg,#8b5cf6,#6366f1);color:#fff}.acp-title-row.data-v-c7555b13{display:flex;align-items:center;gap:10rpx}.acp-icon.data-v-c7555b13{font-size:32rpx}.acp-title.data-v-c7555b13{font-size:28rpx;font-weight:700}.acp-badge.data-v-c7555b13{padding:2rpx 10rpx;font-size:18rpx;font-weight:600;color:#6366f1;background:rgba(255,255,255,.9);border-radius:6rpx}.acp-close.data-v-c7555b13{width:48rpx;height:48rpx;display:flex;align-items:center;justify-content:center;font-size:28rpx;color:#fff;opacity:.8}.acp-messages.data-v-c7555b13{flex:1;max-height:380rpx;padding:20rpx 24rpx