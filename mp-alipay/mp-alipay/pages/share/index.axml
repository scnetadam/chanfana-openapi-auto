<view class="share-page data-v-49e1a32d"><view a:if="{{a}}" class="loading data-v-49e1a32d"><text class="load-text data-v-49e1a32d">加载中...</text></view><block a:elif="{{b}}"><view class="content-card data-v-49e1a32d"><view class="cc-header data-v-49e1a32d"><text class="cc-badge data-v-49e1a32d">{{c}}</text></view><text a:if="{{d}}" class="cc-activity data-v-49e1a32d">{{e}}</text><text class="cc-text data-v-49e1a32d">{{f}}</text></view><view class="stats-bar data-v-49e1a32d"><view class="stats-item data-v-49e1a32d"><text class="stats-icon data-v-49e1a32d">👁️</text><text class="stats-value data-v-49e1a32d">{{g}}</text><text class="stats-label data-v-49e1a32d">阅读</text></view><view class="stats-item data-v-49e1a32d"><text class="stats-icon data-v-49e1a32d">📋</text><text class="stats-value accent data-v-49e1a32d">{{h}}</text><text class="stats-label data-v-49e1a32d">预约</text></view><view class="stats-item earnings data-v-49e1a32d"><text class="stats-icon data-v-49e1a32d">💰</text><text class="stats-value gold data-v-49e1a32d">¥{{i}}</text><text class="stats-label data-v-49e1a32d">收益</text></view></view><view a:if="{{j}}" class="booking-section data-v-49e1a32d"><text class="bs-title data-v-49e1a32d">📋 预约试驾 {{k}}</text><view class="form-group data-v-49e1a32d"><text class="form-label data-v-49e1a32d">姓名</text><input class="form-input data-v-49e1a32d" placeholder="请输入姓名" value="{{l}}" onInput="{{m}}"/></view><view class="form-group data-v-49e1a32d"><text class="form-label data-v-49e1a32d">手机号</text><input class="form-input data-v-49e1a32d" placeholder="请输入手机号" type="tel" maxlength="11" value="{{n}}" onInput="{{o}}"/></view><button class="submit-btn data-v-49e1a32d" loading="{{p}}" disabled="{{q}}" onTap="{{r}}"><text class="data-v-49e1a32d">提交预约</text></button></view><view a:else class="success-section data-v-49e1a32d"><text class="success-title data-v-49e1a32d">预约成功！</text><text class="success-desc data-v-49e1a32d">4S店顾问将在24小时内联系你</text></view><view class="action-bar data-v-49e1a32d"><button class="action-btn share data-v-49e1a32d" onTap="{{s}}"><text class="data-v-49e1a32d">🔗 分享</text></button><button class="action-btn copy data-v-49e1a32d" onTap="{{t}}"><text class="data-v-49e1a32d">📎 复制链接</text></button><button class="action-btn poster data-v-49e1a32d" onTap="{{v}}"><text class="data-v-49e1a32d">🖼️ 海报</text></button></view></block><view a:else class="loading data-v-49e1a32d"><text class="data-v-49e1a32d">内容不存在</text></view><view a:if="{{w}}" class="ai-fab data-v-49e1a32d" onTap="{{x}}"><text class="ai-fab-icon data-v-49e1a32d">🤖</text><text class="ai-fab-label data-v-49e1a32d">AI顾问</text></view><view a:if="{{y}}" class="ai-chat-panel data-v-49e1a32d"><view class="acp-header data-v-49e1a32d"><view class="acp-title-row data-v-49e1a32d"><text class="acp-icon data-v-49e1a32d">🤖</text><text class="acp-title data-v-49e1a32d">AI 汽车顾问</text><text class="acp-badge data-v-49e1a32d">NEW</text></view><view class="acp-close data-v-49e1a32d" onTap="{{z}}"><text class="data-v-49e1a32d">✕</text></view></view><scroll-view class="acp-messages data-v-49e1a32d" scroll-y scroll-into-view="{{C}}"><view a:for="{{A}}" a:for-item="msg" a:key="b" id="{{msg.c}}" class="{{('acp-msg') + ' ' + 'data-v-49e1a32d' + ' ' + msg.d}}"><text class="acp-msg-text data-v-49e1a32d">{{msg.a}}</text></view><view a:if="{{B}}" class="acp-msg assistant data-v-49e1a32d"><text class="acp-msg-text acp-typing data-v-49e1a32d">思考中...</text></view></scroll-view><view a:if="{{D}}" class="acp-suggestions data-v-49e1a32d"><view a:for="{{E}}" a:for-item="sq" a:key="b" class="acp-sq-btn data-v-49e1a32d" onTap="{{sq.c}}"><text class="data-v-49e1a32d">{{sq.a}}</text></view></view><view class="acp-input-bar data-v-49e1a32d"><input class="acp-input data-v-49e1a32d" placeholder="问点关于这款车的问题..." onConfirm="{{F}}" value="{{G}}" onInput="{{H}}"/><button class="acp-send-btn data-v-49e1a32d" onTap="{{I}}" disabled="{{J}}"><text class="data-v-49e1a32d">发送</text></button></view></view></view>