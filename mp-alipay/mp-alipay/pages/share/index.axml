<view class="share-page data-v-c7555b13"><view a:if="{{a}}" class="loading data-v-c7555b13"><text class="load-text data-v-c7555b13">加载中...</text></view><block a:elif="{{b}}"><view class="content-card data-v-c7555b13"><view class="cc-header data-v-c7555b13"><text class="cc-badge data-v-c7555b13">{{c}}</text></view><text a:if="{{d}}" class="cc-activity data-v-c7555b13">{{e}}</text><text class="cc-text data-v-c7555b13">{{f}}</text></view><view class="stats-bar data-v-c7555b13"><view class="stats-item data-v-c7555b13"><text class="stats-icon data-v-c7555b13">👁️</text><text class="stats-value data-v-c7555b13">{{g}}</text><text class="stats-label data-v-c7555b13">阅读</text></view><view class="stats-item data-v-c7555b13"><text class="stats-icon data-v-c7555b13">📋</text><text class="stats-value accent data-v-c7555b13">{{h}}</text><text class="stats-label data-v-c7555b13">预约</text></view><view class="stats-item earnings data-v-c7555b13"><text class="stats-icon data-v-c7555b13">💰</text><text class="stats-value gold data-v-c7555b13">¥{{i}}</text><text class="stats-label data-v-c7555b13">收益</text></view></view><view a:if="{{j}}" class="booking-section data-v-c7555b13"><text class="bs-title data-v-c7555b13">📋 预约试驾 {{k}}</text><view class="form-group data-v-c7555b13"><text class="form-label data-v-c7555b13">姓名</text><input class="form-input data-v-c7555b13" placeholder="请输入姓名" value="{{l}}" onInput="{{m}}"/></view><view class="form-group data-v-c7555b13"><text class="form-label data-v-c7555b13">手机号</text><input class="form-input data-v-c7555b13" placeholder="请输入手机号" type="tel" maxlength="11" value="{{n}}" onInput="{{o}}"/></view><button class="submit-btn data-v-c7555b13" loading="{{p}}" disabled="{{q}}" onTap="{{r}}"><text class="data-v-c7555b13">提交预约</text></button></view><view a:else class="success-section data-v-c7555b13"><text class="success-title data-v-c7555b13">预约成功！</text><text class="success-desc data-v-c7555b13">4S店顾问将在24小时内联系你</text></view><view class="action-bar data-v-c7555b13"><button class="action-btn share data-v-c7555b13" onTap="{{s}}"><text class="data-v-c7555b13">🔗 分享</text></button><button class="action-btn copy data-v-c7555b13" onTap="{{t}}"><text class="data-v-c7555b13">📎 复制链接</text></button></view></block><view a:else class="loading data-v-c7555b13"><text class="data-v-c7555b13">内容不存在</text></view><view a:if="{{v}}" class="ai-fab data-v-c7555b13" onTap="{{w}}"><text class="ai-fab-icon data-v-c7555b13">🤖</text><text class="ai-fab-label data-v-c7555b13">AI顾问</text></view><view a:if="{{x}}" class="ai-chat-panel data-v-c7555b13"><view class="acp-header data-v-c7555b13"><view class="acp-title-row data-v-c7555b13"><text class="acp-icon data-v-c7555b13">🤖</text><text class="acp-title data-v-c7555b13">AI 汽车顾问</text><text class="acp-badge data-v-c7555b13">NEW</text></view><view class="acp-close data-v-c7555b13" onTap="{{y}}"><text class="data-v-c7555b13">✕</text></view></view><scroll-view class="acp-messages data-v-c7555b13" scroll-y scroll-into-view="{{B}}"><view a:for="{{z}}" a:for-item="msg" a:key="b" id="{{msg.c}}" class="{{('acp-msg') + ' ' + 'data-v-c7555b13' + ' ' + msg.d}}"><text class="acp-msg-text data-v-c7555b13">{{msg.a}}</text></view><view a:if="{{A}}" class="acp-msg assistant data-v-c7555b13"><text class="acp-msg-text acp-typing data-v-c7555b13">思考中...</text></view></scroll-view><view a:if="{{C}}" class="acp-suggestions data-v-c7555b13"><view a:for="{{D}}" a:for-item="sq" a:key="b" class="acp-sq-btn data-v-c7555b13" onTap="{{sq.c}}"><text class="data-v-c7555b13">{{sq.a}}</text></view></view><view class="acp-input-bar data-v-c7555b13"><input class="acp-input data-v-c7555b13" placeholder="问点关于这款车的问题..." onConfirm="{{E}}" value="{{F}}" onInput="{{G}}"/><button class="acp-send-btn data-v-c7555b13" onTap="{{H}}" disabled="{{I}}"><text class="data-v-c7555b13">发送</text></button></view></view></view>