<view class="page data-v-c0mp1ance"><view class="header data-v-c0mp1ance"><text class="header-title data-v-c0mp1ance">e-CNY钱包</text><text class="header-sub data-v-c0mp1ance">数字人民币管理</text></view><view a:if="{{a}}" class="loading data-v-c0mp1ance"><text class="data-v-c0mp1ance">加载中...</text></view><view a:elif="{{j}}" class="data-v-c0mp1ance"><view class="create-card data-v-c0mp1ance"><text class="create-title data-v-c0mp1ance">开通e-CNY钱包</text><text class="create-desc data-v-c0mp1ance">开通数字人民币钱包，支持合规资金追溯</text><button class="create-btn data-v-c0mp1ance" loading="{{b}}" onTap="{{c}}">立即开通</button></view></view><view a:elif="{{d}}" class="data-v-c0mp1ance"><view class="wallet-card data-v-c0mp1ance"><text class="wallet-balance data-v-c0mp1ance">¥{{e}}</text><view class="wallet-meta data-v-c0mp1ance"><text class="wallet-type data-v-c0mp1ance">{{f}}</text><text class="wallet-status {{h}} data-v-c0mp1ance">{{g}}</text></view></view><view class="section data-v-c0mp1ance"><text class="section-title data-v-c0mp1ance">流水记录</text><view a:for="{{i}}" a:for-item="item" a:key="g" class="flow-card data-v-c0mp1ance"><view class="flow-top data-v-c0mp1ance"><text class="flow-dir {{item.b}} data-v-c0mp1ance">{{item.a}}</text><text class="flow-amount data-v-c0mp1ance">{{item.c}}¥{{item.d}}</text></view><view class="flow-bottom data-v-c0mp1ance"><text class="flow-status data-v-c0mp1ance">{{item.e}}</text><text class="flow-date data-v-c0mp1ance">{{item.f}}</text></view></view></view></view></view>