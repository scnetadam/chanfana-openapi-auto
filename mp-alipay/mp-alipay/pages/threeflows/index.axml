<view class="page data-v-c0mp1ance"><view class="header data-v-c0mp1ance"><text class="header-title data-v-c0mp1ance">三流核验</text><text class="header-sub data-v-c0mp1ance">业务流·资金流·发票流</text></view><view class="filter-row data-v-c0mp1ance"><text class="{{('data-v-c0mp1ance') + ' ' + 'filter' + ' ' + a}}" onTap="{{b}}">全部</text><text class="{{('data-v-c0mp1ance') + ' ' + 'filter' + ' ' + c}}" onTap="{{d}}">匹配</text><text class="{{('data-v-c0mp1ance') + ' ' + 'filter' + ' ' + e}}" onTap="{{f}}">不匹配</text><text class="{{('data-v-c0mp1ance') + ' ' + 'filter' + ' ' + g}}" onTap="{{h}}">部分</text></view><view a:if="{{i}}" class="loading data-v-c0mp1ance"><text class="data-v-c0mp1ance">加载中...</text></view><view a:elif="{{k}}" class="empty data-v-c0mp1ance"><text class="data-v-c0mp1ance">暂无核验记录</text></view><scroll-view a:else scroll-y class="check-list data-v-c0mp1ance"><view a:for="{{j}}" a:for-item="item" a:key="h" class="check-card data-v-c0mp1ance"><view class="check-row data-v-c0mp1ance"><text class="check-label data-v-c0mp1ance">业务Hash</text><text class="check-val data-v-c0mp1ance">{{item.a}}</text></view><view class="check-row data-v-c0mp1ance"><text class="check-label data-v-c0mp1ance">e-CNY流</text><text class="check-val data-v-c0mp1ance">{{item.b}}</text></view><view class="check-row data-v-c0mp1ance"><text class="check-label data-v-c0mp1ance">发票ID</text><text class="check-val data-v-c0mp1ance">{{item.c}}</text></view><view class="check-footer data-v-c0mp1ance"><text class="check-status {{item.e}} data-v-c0mp1ance">{{item.d}}</text><text class="check-amount data-v-c0mp1ance">¥{{item.f}}</text><text class="check-date data-v-c0mp1ance">{{item.g}}</text></view></view></scroll-view></view>