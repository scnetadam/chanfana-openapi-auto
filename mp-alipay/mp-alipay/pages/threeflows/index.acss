.page.data-v-c0mp1ance{min-height:100vh;background:#f0f2f5;padding-bottom:120rpx}.header.data-v-c0mp1ance{padding:32rpx 32rpx 8rpx}.header-title.data-v-c0mp1ance{font-size:44rpx;font-weight:700;color:#1f2937;display:block}.header-sub.data-v-c0mp1ance{font-size:24rpx;color:#9ca3af;margin-top:4rpx;display:block}.filter-row.data-v-c0mp1ance{display:flex;padding:0 32rpx;margin-bottom:16rpx;gap:12rpx}.filter.data-v-c0mp1ance{font-size:26rpx;color:#9ca3af;padding:8rpx 20rpx;border-radius:24rpx;background:#fff}.filter.active.data-v-c0mp1ance{color:#10b981;font-weight:600;background:#ecfdf5}.loading.data-v-c0mp1ance,.empty.data-v-c0mp1ance{display:flex;justify-content:center;padding:120rpx 0;color:#9ca3af;font-size:28rpx}.check-list.data-v-c0mp1ance{padding:0 24rpx}.check-card.data-v-c0mp1ance{background:#fff;border-radius:16rpx;padding:24rpx;margin-bottom:12rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.02)}.check-row.data-v-c0mp1ance{display:flex;justify-content:space-between;align-items:center;padding:8rpx 0;border-bottom:2rpx solid #f3f4f6}.check-row:last-of-type.data-v-c0mp1ance{border-bottom:none}.check-label.data-v-c0mp1ance{font-size:24rpx;color:#9ca3af;min-width:120rpx}.check-val.data-v-c0mp1ance{font-size:24rpx;color:#1f2937;font-weight:500;flex:1;text-align:right;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.check-footer.data-v-c0mp1ance{display:flex;align-items:center;gap:16rpx;margin-top:12rpx;padding-top:12rpx;border-top:2rpx solid #f3f4f6}.check-status.data-v-c0mp1ance{font-size:22rpx;padding:4rpx 16rpx;border-radius:8rpx;font-weight:500}.check-status.status-matched.data-v-c0mp1ance{color:#10b981;background:#ecfdf5}.check-status.status-mismatched.data-v-c0mp1ance{color:#ef4444;background:#fef2f2}.check-status.status-partial.data-v-c0mp1ance{color:#f59e0b;background:#fffbeb}.check-amount.data-v-c0mp1ance{font-size:28rpx;font-weight:600;color:#1f2937;flex:1;text-align:right}.check-date.data-v-c0mp1ance{font-size:22rpx;color:#9ca3af}