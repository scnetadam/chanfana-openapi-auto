<view class="page data-v-bab7f42e"><view class="header data-v-bab7f42e"><text class="header-title data-v-bab7f42e">结算中心</text><text class="header-sub data-v-bab7f42e">龟钮印证微交易结算</text></view><view a:if="{{a}}" class="stats-grid data-v-bab7f42e"><view class="stat-card income data-v-bab7f42e"><text class="stat-val data-v-bab7f42e">¥{{b}}</text><text class="stat-lbl data-v-bab7f42e">总收入</text></view><view class="stat-card expense data-v-bab7f42e"><text class="stat-val data-v-bab7f42e">¥{{c}}</text><text class="stat-lbl data-v-bab7f42e">总支出</text></view><view class="stat-card fee data-v-bab7f42e"><text class="stat-val data-v-bab7f42e">¥{{d}}</text><text class="stat-lbl data-v-bab7f42e">手续费(0.6%)</text></view><view class="stat-card pending data-v-bab7f42e"><text class="stat-val data-v-bab7f42e">{{e}}</text><text class="stat-lbl data-v-bab7f42e">待结算</text></view></view><view class="filter-row data-v-bab7f42e"><text class="{{('data-v-bab7f42e') + ' ' + 'filter' + ' ' + f}}" onTap="{{g}}">全部</text><text class="{{('data-v-bab7f42e') + ' ' + 'filter' + ' ' + h}}" onTap="{{i}}">待结算</text><text class="{{('data-v-bab7f42e') + ' ' + 'filter' + ' ' + j}}" onTap="{{k}}">已完成</text></view><view a:if="{{l}}" class="loading data-v-bab7f42e"><text class="data-v-bab7f42e">加载中...</text></view><view a:elif="{{m}}" class="empty data-v-bab7f42e"><text class="data-v-bab7f42e">暂无结算记录</text></view><scroll-view a:else scroll-y class="settlement-list data-v-bab7f42e"><view a:for="{{n}}" a:for-item="item" a:key="q" class="settlement-card data-v-bab7f42e"><view class="settlement-top data-v-bab7f42e"><view class="settlement-info data-v-bab7f42e"><text class="settlement-type data-v-bab7f42e">{{item.a}}</text><text a:if="{{item.b}}" class="settlement-desc data-v-bab7f42e">{{item.c}}</text></view><view class="settlement-amount-row data-v-bab7f42e"><text class="{{('data-v-bab7f42e') + ' ' + 'settlement-amount' + ' ' + item.f}}">{{item.d}}¥{{item.e}}</text></view></view><view class="settlement-bottom data-v-bab7f42e"><view class="settlement-meta data-v-bab7f42e"><text class="meta-text data-v-bab7f42e">{{item.g}}</text><text a:if="{{item.h}}" class="meta-fee data-v-bab7f42e">手续费 ¥{{item.i}}</text></view><view class="settlement-right data-v-bab7f42e"><text a:if="{{item.j}}" class="hash-badge data-v-bab7f42e">HASH存证</text><text a:if="{{item.k}}" class="ai-badge data-v-bab7f42e">AI验证</text><text class="status-badge data-v-bab7f42e" style="{{'color:' + item.m + ';' + ('border-color:' + item.n)}}">{{item.l}}</text><button a:if="{{item.o}}" class="exec-btn data-v-bab7f42e" onTap="{{item.p}}">结算</button></view></view></view></scroll-view></view>