<view class="page data-v-cb8255d1"><view a:if="{{a}}" class="loading data-v-cb8255d1"><text class="data-v-cb8255d1">加载中...</text></view><view a:elif="{{b}}" class="cert-approved data-v-cb8255d1"><text class="approved-icon data-v-cb8255d1">✓</text><text class="approved-title data-v-cb8255d1">认证已通过</text><text class="approved-desc data-v-cb8255d1">您已通过龟钮印证商家认证，可发布KOL任务和商家产品</text><view class="menu-list data-v-cb8255d1"><view class="menu-item data-v-cb8255d1" onTap="{{c}}"><text class="menu-label data-v-cb8255d1">KOL任务中心</text><text class="menu-arrow data-v-cb8255d1">&gt;</text></view><view class="menu-divider data-v-cb8255d1"></view><view class="menu-item data-v-cb8255d1" onTap="{{d}}"><text class="menu-label data-v-cb8255d1">结算中心</text><text class="menu-arrow data-v-cb8255d1">&gt;</text></view></view></view><view a:elif="{{e}}" class="cert-pending data-v-cb8255d1"><text class="pending-icon data-v-cb8255d1">⏳</text><text class="pending-title data-v-cb8255d1">审核中</text><text class="pending-desc data-v-cb8255d1">您的认证申请正在AI审核中，请稍候</text></view><scroll-view a:else scroll-y class="cert-form data-v-cb8255d1"><view class="form-header data-v-cb8255d1"><text class="form-title data-v-cb8255d1">入驻龟钮印证</text><text class="form-desc data-v-cb8255d1">完成商家认证后，可发布KOL任务、创建商家产品、通过龟钮印证实现微交易结算</text></view><view class="form-section data-v-cb8255d1"><view class="form-item data-v-cb8255d1"><text class="form-label data-v-cb8255d1">企业名称 *</text><input class="form-input data-v-cb8255d1" placeholder="请输入企业全称" value="{{f}}" onInput="{{g}}"/></view><view class="form-item data-v-cb8255d1"><text class="form-label data-v-cb8255d1">统一社会信用代码</text><input class="form-input data-v-cb8255d1" placeholder="18位信用代码 (选填)" value="{{h}}" onInput="{{i}}"/></view><view class="form-item data-v-cb8255d1"><text class="form-label data-v-cb8255d1">法人代表</text><input class="form-input data-v-cb8255d1" placeholder="法人姓名 (选填)" value="{{j}}" onInput="{{k}}"/></view><view class="form-item data-v-cb8255d1"><text class="form-label data-v-cb8255d1">联系人 *</text><input class="form-input data-v-cb8255d1" placeholder="联系人姓名" value="{{l}}" onInput="{{m}}"/></view><view class="form-item data-v-cb8255d1"><text class="form-label data-v-cb8255d1">联系电话 *</text><input class="form-input data-v-cb8255d1" placeholder="手机号码" type="number" value="{{n}}" onInput="{{o}}"/></view><view class="form-item data-v-cb8255d1"><text class="form-label data-v-cb8255d1">所属行业</text><input class="form-input data-v-cb8255d1" placeholder="如: 汽车/科技/零售" value="{{p}}" onInput="{{q}}"/></view><view class="form-item data-v-cb8255d1"><text class="form-label data-v-cb8255d1">企业规模</text><input class="form-input data-v-cb8255d1" placeholder="如: 小型/中型/大型" value="{{r}}" onInput="{{s}}"/></view></view><button class="submit-btn data-v-cb8255d1" disabled="{{v}}" onTap="{{w}}">{{t}}</button></scroll-view></view>