<view class="page data-v-c0mp1ance"><view class="header data-v-c0mp1ance"><text class="header-title data-v-c0mp1ance">发票管理</text><text class="header-sub data-v-c0mp1ance">合规开票与发票查询</text></view><button class="issue-toggle-btn data-v-c0mp1ance" onTap="{{a}}">+ 开具发票</button><view a:if="{{b}}" class="issue-form data-v-c0mp1ance"><view class="form-group data-v-c0mp1ance"><text class="form-label data-v-c0mp1ance">发票类型</text><view class="type-row data-v-c0mp1ance"><text class="{{('data-v-c0mp1ance') + ' ' + 'type-btn' + ' ' + c}}" onTap="{{d}}">普票</text><text class="{{('data-v-c0mp1ance') + ' ' + 'type-btn' + ' ' + e}}" onTap="{{f}}">专票</text></view></view><view class="form-group data-v-c0mp1ance"><text class="form-label data-v-c0mp1ance">收票方轨道</text><view class="track-row data-v-c0mp1ance"><text class="{{('data-v-c0mp1ance') + ' ' + 'track-btn' + ' ' + g}}" onTap="{{h}}">A轨</text><text class="{{('data-v-c0mp1ance') + ' ' + 'track-btn' + ' ' + i}}" onTap="{{j}}">B轨</text><text class="{{('data-v-c0mp1ance') + ' ' + 'track-btn' + ' ' + k}}" onTap="{{l}}">C轨</text></view></view><view class="form-group data-v-c0mp1ance"><text class="form-label data-v-c0mp1ance">金额</text><input class="form-input data-v-c0mp1ance" type="digit" value="{{m}}" onInput="{{n}}" placeholder="请输入金额" /></view><button class="issue-btn data-v-c0mp1ance" loading="{{o}}" onTap="{{p}}">确认开票</button></view><view a:if="{{q}}" class="loading data-v-c0mp1ance"><text class="data-v-c0mp1ance">加载中...</text></view><view a:elif="{{s}}" class="empty data-v-c0mp1ance"><text class="data-v-c0mp1ance">暂无发票记录</text></view><scroll-view a:else scroll-y class="invoice-list data-v-c0mp1ance"><view a:for="{{r}}" a:for-item="item" a:key="h" class="invoice-card data-v-c0mp1ance"><view class="inv-top data-v-c0mp1ance"><text class="inv-no data-v-c0mp1ance">{{item.a}}</text><text class="inv-type data-v-c0mp1ance">{{item.b}}</text></view><view class="inv-mid data-v-c0mp1ance"><text class="inv-track data-v-c0mp1ance">{{item.c}}轨</text><text class="inv-amount data-v-c0mp1ance">¥{{item.d}}</text></view><view class="inv-bottom data-v-c0mp1ance"><text class="inv-tax data-v-c0mp1ance">税额 ¥{{item.e}}</text><text class="inv-status {{item.g}} data-v-c0mp1ance">{{item.f}}</text></view></view></scroll-view></view>