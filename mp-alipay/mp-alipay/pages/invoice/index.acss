.page.data-v-c0mp1ance{min-height:100vh;background:#f0f2f5;padding-bottom:120rpx}.header.data-v-c0mp1ance{padding:32rpx 32rpx 8rpx}.header-title.data-v-c0mp1ance{font-size:44rpx;font-weight:700;color:#1f2937;display:block}.header-sub.data-v-c0mp1ance{font-size:24rpx;color:#9ca3af;margin-top:4rpx;display:block}.issue-toggle-btn.data-v-c0mp1ance{margin:16rpx 24rpx;background:#2563eb;color:#fff;font-size:28rpx;font-weight:600;border-radius:24rpx;padding:12rpx 0}.issue-toggle-btn.data-v-c0mp1ance:after{border:none}.issue-form.data-v-c0mp1ance{margin:0 24rpx 16rpx;background:#fff;border-radius:16rpx;padding:24rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.02)}.form-group.data-v-c0mp1ance{margin-bottom:20rpx}.form-label.data-v-c0mp1ance{font-size:26rpx;color:#6b7280;display:block;margin-bottom:8rpx}.type-row.data-v-c0mp1ance,.track-row.data-v-c0mp1ance{display:flex;gap:12rpx}.type-btn.data-v-c0mp1ance,.track-btn.data-v-c0mp1ance{flex:1;text-align:center;font-size:26rpx;padding:12rpx 0;border-radius:12rpx;background:#f3f4f6;color:#6b7280}.type-btn.active.data-v-c0mp1ance,.track-btn.active.data-v-c0mp1ance{background:#2563eb;color:#fff;font-weight:600}.form-input.data-v-c0mp1ance{font-size:28rpx;padding:16rpx;background:#f9fafb;border-radius:12rpx;border:2rpx solid #e5e7eb}.issue-btn.data-v-c0mp1ance{margin-top:16rpx;background:#10b981;color:#fff;font-size:28rpx;font-weight:600;border-radius:24rpx;padding:12rpx 0}.issue-btn.data-v-c0mp1ance:after{border:none}.loading.data-v-c0mp1ance,.empty.data-v-c0mp1ance{display:flex;justify-content:center;padding:120rpx 0;color:#9ca3af;font-size:28rpx}.invoice-list.data-v-c0mp1ance{padding:0 24rpx}.invoice-card.data-v-c0mp1ance{background:#fff;border-radius:16rpx;padding:20rpx;margin-bottom:8rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.02)}.inv-top.data-v-c0mp1ance{display:flex;justify-content:space-between;align-items:center;margin-bottom:8rpx}.inv-no.data-v-c0mp1ance{font-size:26rpx;color:#1f2937;font-weight:500}.inv-type.data-v-c0mp1ance{font-size