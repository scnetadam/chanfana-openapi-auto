.login-page.data-v-7f6865e3{position:relative;display:flex;align-items:center;justify-content:center;min-height:100vh;padding:60rpx 40rpx;background:#fff;overflow:hidden}.bg-arc.data-v-7f6865e3{position:absolute;top:-200rpx;left:-100rpx;right:-100rpx;height:520rpx;background:linear-gradient(135deg,#2563eb,#1d4ed8);border-radius:0 0 50% 50%;opacity:.95}.login-card.data-v-7f6865e3{position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;width:100%;max-width:600rpx;padding:60rpx 40rpx 50rpx;background:#fff;border-radius:32rpx;box-shadow:0 8rpx 48rpx rgba(0,0,0,.08)}.logo-section.data-v-7f6865e3{display:flex;flex-direction:column;align-items:center;margin-bottom:50rpx}.logo-image.data-v-7f6865e3{width:160rpx;height:160rpx;margin-bottom:20rpx;border-radius:24rpx}.app-name.data-v-7f6865e3{font-size:48rpx;font-weight:700;color:#1f2937;letter-spacing:4rpx;margin-bottom:12rpx}.slogan.data-v-7f6865e3{font-size:26rpx;color:#9ca3af;text-align:center;line-height:1.5}.feature-list.data-v-7f6865e3{width:100%;margin-bottom:50rpx}.feature-item.data-v-7f6865e3{display:flex;align-items:center;padding:24rpx 0;border-bottom:2rpx solid #f3f4f6}.feature-item.data-v-7f6865e3:last-child{border-bottom:none}.fi-icon-wrap.data-v-7f6865e3{display:flex;align-items:center;justify-content:center;width:56rpx;height:56rpx;border-radius:14rpx;margin-right:20rpx}.fi-icon.data-v-7f6865e3{font-size:32rpx}.fi-text.data-v-7f6865e3{font-size:28rpx;color:#4b5563;font-weight:500}.login-btn.data-v-7f6865e3{display:flex;align-items:center;justify-content:center;gap:12rpx;width:100%;height:100rpx;line-height:100rpx;font-size:34rpx;font-weight:600;border-radius:50rpx;background:linear-gradient(135deg,#2563eb,#1d4ed8);color:#fff;margin-bottom:36rpx;box-shadow:0 4rpx 16rpx rgba(37,99,235,.3)}.login-btn.data-v-7f6865e3:after{border:none}.login-btn .btn-icon.data-v-7f6865e3{font-size:36rpx;margin-right:4rpx}.agreement.data-v-7f6865e3{font-size:24rpx;color:#d1d5db}.agreement .link.data-v-7f68