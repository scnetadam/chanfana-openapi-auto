# 龟钮印信 v3.0.0 环境变量配置
# 复制本文件为 .env 并填入实际值

# ===== 服务端口 =====
HTTP_PORT=3000
HTTPS_PORT=8443

# ===== 大模型配置 (多Provider可选) =====
# 智谱GLM (默认)
GLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
GLM_API_KEY=
GLM_DEFAULT_MODEL=glm-4

# DeepSeek
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=

# 通义千问 (Qwen)
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=

# Moonshot/Kimi
MOONSHOT_API_BASE=https://api.moonshot.cn/v1
MOONSHOT_API_KEY=

# 百川
BAICHUAN_API_BASE=https://api.baichuan-ai.com/v1
BAICHUAN_API_KEY=

# OpenAI兼容(自定义)
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=
CUSTOM_LLM_API_KEY=

# ===== 龟钮印证 L0 结算壳 =====
# IP数据存证: 龟钮印信本地hashEngine (kol_identity/kol_ip/content_publish/commission等)
# 支付数据存证: 龟钮印证API (settlement_execute/refund/agent_pay等)
# B端认证: 龟钮印证API (biz/apply biz/status)
YINZHENG_API=http://192.168.0.102:80/api

# ===== Agent 微交易支付 =====
AGENT_PAY_API=http://192.168.0.102:80/api/agent-pay
AGENT_PAY_API_KEY=deveco-agent-key-20260709

# ===== Worker (支付宝小程序服务端) =====
WORKER_BASE_URL=
WORKER_AUTH_TOKEN=
