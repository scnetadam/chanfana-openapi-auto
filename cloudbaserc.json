{
  "envId": "d1g9iojop685ea11a",
  "version": "2.0",
  "$schema": "https://framework-1258016615.tcloudbase.com/tcf-framework-json-schema.json",
  "services": [
    {
      "name": "guiniu-xin",
      "containerPort": 80,
      "dockerfile": "./Dockerfile.cloudbase",
      "buildType": "Dockerfile",
      "envVariables": {
        "NODE_ENV": "production",
        "HTTP_PORT": "80",
        "PAYMENT_AMOUNT": "0.01",
        "ALIPAY_GATEWAY": "https://openapi-sandbox.dl.alipaydev.com/gateway.do"
      },
      "scalingPolicy": {
        "mode": "AUTO",
        "minReplicas": 1,
        "maxReplicas": 5
      },
      "cpu": 1,
      "mem": 1,
      "customLogs": "stdout stderr",
      "isReuse": true
    }
  ],
  "storage": {
    "rules": [
      {
        "cloudPath": "/uploads",
        "localPath": "./uploads",
        "access": "publicRead"
      }
    ]
  }
}
